---
import { ArrowRight } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { careerPeriod, experiences } from '../../data/site';
---

<BaseLayout title="Experience" description="기업용 플랫폼 운영 백엔드와 공공·실시간 데이터 파이프라인에서 담당한 문제, 기술적 조치와 검증 범위를 정리합니다.">
  <PageIntro eyebrow="경력 기록" title="경력" description="데이터 수집과 API 구현에서 시작해 기업용 플랫폼의 운영 장애, 상태 정합성, 의존성 전환과 테스트 기반 개선으로 책임 범위를 확장했습니다." />

  <section class="section experience-section">
    <div class="container experience-layout">
      <div class="career-summary">
        <div><span>전체 경력</span><strong>{careerPeriod}</strong></div>
        <p>각 경력은 담당 업무 목록이 아니라 실제 문제, 직접 취한 조치와 확인한 결과를 기준으로 정리했습니다.</p>
        <a href="/resume/">웹 이력서 보기 <ArrowRight size={17} aria-hidden="true" /></a>
      </div>

      <div class="experience-list">
        {experiences.map((experience, experienceIndex) => (
          <article class="experience-entry">
            <header>
              <div>
                <span class="entry-index">0{experienceIndex + 1}</span>
                <p class="eyebrow">{experience.period}</p>
                <h2>{experience.company}</h2>
                <p class="role">{experience.role}</p>
              </div>
              <p class="context">{experience.context}</p>
            </header>

            <div class="experience-cases">
              {experience.highlights.map((highlight, index) => (
                <section>
                  <div class="case-title"><span>{String(index + 1).padStart(2, '0')}</span><h3>{highlight.title}</h3></div>
                  <dl>
                    <div><dt>문제</dt><dd>{highlight.problem}</dd></div>
                    <div><dt>조치</dt><dd>{highlight.action}</dd></div>
                    <div><dt>확인</dt><dd>{highlight.result}</dd></div>
                  </dl>
                </section>
              ))}
            </div>

            <div class="experience-stack">
              <span>사용 범위</span>
              <ul class="tag-list">{experience.stack.map((item) => <li class="tag">{item}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--surface work-principles" aria-labelledby="work-principles-title">
    <div class="container">
      <div class="section-heading section-heading--indexed">
        <span class="section-number">03</span>
        <div><h2 id="work-principles-title">업무 원칙</h2><p class="section-deck">재현, 경계 설정과 검증을 분리해 기록합니다.</p></div>
        <p class="lede">무엇을 고쳤는지보다 어떤 현상을 재현했고, 수정 범위를 어디까지 좁혔으며, 각 검증이 무엇을 증명하는지 구분합니다.</p>
      </div>
      <div class="principle-grid">
        <div><p class="eyebrow">01 · 재현</p><h3>현상을 먼저 고정합니다.</h3><p>로그 한 줄로 결론을 내리지 않고 시간대, 상태 변화, 요청 조합과 저장 결과를 함께 재현합니다.</p></div>
        <div><p class="eyebrow">02 · 경계</p><h3>수정 범위를 좁힙니다.</h3><p>영향받는 API, 저장소와 외부 의존성을 분리하고 정상 경로와 차단 경로를 같은 기준으로 검토합니다.</p></div>
        <div><p class="eyebrow">03 · 검증</p><h3>결과를 여러 층에서 확인합니다.</h3><p>단위·통합 테스트, 의존성·산출물 검사와 스테이징 QA가 각자 무엇을 증명하는지 구분합니다.</p></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .experience-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: start;
  }

  .career-summary {
    display: grid;
    grid-template-columns: 190px minmax(0, 1fr) auto;
    gap: 32px;
    align-items: center;
    padding-block: 20px;
    border-block: 1px solid var(--line-strong);
  }

  .career-summary > div {
    display: grid;
    gap: 4px;
  }

  .career-summary span {
    color: var(--blue);
    font-size: 0.86rem;
    font-weight: 780;
  }

  .career-summary strong {
    font-family: var(--mono);
    font-size: 1.05rem;
  }

  .career-summary > p {
    color: var(--ink-soft);
    font-size: 0.96rem;
  }

  .career-summary a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 5px;
    font-size: 0.9rem;
    font-weight: 900;
  }

  .experience-list {
    display: grid;
    gap: 72px;
  }

  .experience-entry header {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 1fr);
    gap: 44px;
    align-items: end;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--ink);
  }

  .entry-index {
    display: block;
    margin-bottom: 20px;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.84rem;
  }

  .experience-entry h2 {
    font-size: 2.1rem;
  }

  .role {
    margin-top: 8px;
    color: var(--ink-soft);
    font-weight: 800;
  }

  .context {
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  .experience-cases {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-left: 1px solid var(--line-strong);
  }

  .experience-cases section {
    padding: 24px;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
  }

  .case-title {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .case-title span {
    color: var(--blue);
    font-family: var(--mono);
    font-size: 0.82rem;
  }

  .case-title h3 {
    font-size: 1.2rem;
  }

  .experience-cases dl {
    display: grid;
    gap: 14px;
    margin: 22px 0 0;
  }

  .experience-cases dl > div {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 10px;
  }

  .experience-cases dt {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .experience-cases dd {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  .experience-stack {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 18px;
    padding-top: 20px;
  }

  .experience-stack > span {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .principle-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--line-strong);
    border-left: 1px solid var(--line-strong);
  }

  .principle-grid > div {
    padding: 24px;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
  }

  .principle-grid h3 {
    margin-bottom: 15px;
    font-size: 1.3rem;
  }

  .principle-grid p:last-child {
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  @media (max-width: 940px) {
    .career-summary {
      grid-template-columns: 160px minmax(0, 1fr);
    }

    .career-summary a {
      grid-column: 2;
    }
  }

  @media (max-width: 720px) {
    :global(.page-intro.page-intro) {
      padding-block: 36px 32px;
    }

    :global(.page-intro .intro-grid) {
      gap: 14px;
    }

    .experience-section {
      padding-block: 38px;
    }

    .experience-layout {
      gap: 30px;
    }

    .career-summary {
      grid-template-columns: 1fr;
      gap: 12px;
      padding-top: 12px;
    }

    .career-summary a {
      grid-column: 1;
    }

    .experience-list {
      gap: 48px;
    }

    .experience-entry header,
    .experience-cases,
    .principle-grid {
      grid-template-columns: 1fr;
    }

    .experience-entry header {
      gap: 14px;
      padding-bottom: 18px;
    }

    .entry-index {
      margin-bottom: 10px;
    }

    .experience-entry h2 {
      font-size: 1.85rem;
    }

    .context {
      font-size: 0.94rem;
    }

    .experience-cases section,
    .principle-grid > div {
      padding: 16px;
    }

    .experience-cases dl {
      gap: 10px;
      margin-top: 15px;
    }

    .experience-stack {
      grid-template-columns: 1fr;
      gap: 8px;
      padding-top: 14px;
    }

    .work-principles {
      padding-block: 40px;
    }
  }
</style>
