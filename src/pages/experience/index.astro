---
import { ArrowRight } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { careerPeriod, experiences } from '../../data/site';
---

<BaseLayout title="경력" description="기업용 플랫폼과 공공·실시간 데이터 서비스에서 맡은 역할과 주요 업무를 정리했습니다.">
  <PageIntro title="경력" description="공공·실시간 데이터 수집부터 기업용 플랫폼 API 개발·운영까지 맡아 온 역할과 주요 업무를 정리했습니다." />

  <section class="section experience-section">
    <div class="container experience-layout">
      <div class="career-summary">
        <div><span>전체 경력</span><strong>{careerPeriod}</strong></div>
        <p>회사별 역할과 주요 업무를 최근 경력부터 정리했습니다.</p>
        <a href="/resume/">웹 이력서 보기 <ArrowRight size={17} aria-hidden="true" /></a>
      </div>

      <div class="experience-list">
        {experiences.map((experience) => (
          <article class="experience-entry">
            <header>
              <div>
                <p class="eyebrow">{experience.period}</p>
                <h2>{experience.company}</h2>
                <p class="role">{experience.role}</p>
              </div>
              <p class="context">{experience.context}</p>
            </header>

            <section class="responsibilities">
              <h3>주요 업무</h3>
              <ul>
                {experience.responsibilities.map((responsibility) => (
                  <li>
                    <h4>{responsibility.title}</h4>
                    <p>{responsibility.description}</p>
                  </li>
                ))}
              </ul>
            </section>

            <div class="experience-stack">
              <span>기술 스택</span>
              <ul class="tag-list">{experience.stack.map((item) => <li class="tag">{item}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .experience-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: start;
  }

  .career-summary {
    display: grid;
    grid-template-columns: 190px minmax(0, 1fr) auto;
    gap: 32px;
    align-items: center;
    padding-block: 20px;
    border-block: 1px solid var(--line-strong);
  }

  .career-summary > div {
    display: grid;
    gap: 4px;
  }

  .career-summary span {
    color: var(--blue);
    font-size: var(--text-label);
    font-weight: 780;
  }

  .career-summary strong {
    font-family: var(--mono);
    font-size: var(--text-body);
  }

  .career-summary > p {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .career-summary a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 5px;
    font-size: 16px;
    font-weight: 900;
  }

  .experience-list {
    display: grid;
    gap: 64px;
  }

  .experience-entry header {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 1fr);
    gap: 44px;
    align-items: end;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--ink);
  }

  .experience-entry h2 {
    font-size: var(--text-h2);
  }

  .role {
    margin-top: 8px;
    color: var(--ink-soft);
    font-weight: 800;
  }

  .context {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .responsibilities {
    display: grid;
    grid-template-columns: 100px minmax(0, 1fr);
    gap: 18px;
    padding-block: 24px;
    border-bottom: 1px solid var(--line-strong);
  }

  .responsibilities > h3 {
    color: var(--ink-faint);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .responsibilities ul {
    display: grid;
    gap: 18px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .responsibilities li {
    display: grid;
    grid-template-columns: minmax(150px, 0.36fr) minmax(0, 1fr);
    gap: 24px;
  }

  .responsibilities h4 {
    font-size: var(--text-dense);
  }

  .responsibilities p {
    margin: 0;
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .experience-stack {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 18px;
    padding-top: 20px;
  }

  .experience-stack > span {
    color: var(--ink-faint);
    font-family: var(--sans);
    font-size: var(--text-label);
    font-weight: 800;
  }

  @media (max-width: 959px) {
    .career-summary {
      grid-template-columns: 160px minmax(0, 1fr);
    }

    .career-summary a {
      grid-column: 2;
    }
  }

  @media (max-width: 639px) {
    .experience-section {
      padding-block: 48px;
    }

    .experience-layout {
      gap: 30px;
    }

    .career-summary {
      grid-template-columns: 1fr;
      gap: 12px;
      padding-top: 12px;
    }

    .career-summary a {
      grid-column: 1;
    }

    .experience-list {
      gap: 48px;
    }

    .experience-entry header,
    .responsibilities,
    .responsibilities li {
      grid-template-columns: 1fr;
    }

    .experience-entry header {
      gap: 14px;
      padding-bottom: 18px;
    }

    .responsibilities {
      gap: 14px;
      padding-block: 20px;
    }

    .responsibilities li {
      gap: 5px;
    }

    .experience-stack {
      grid-template-columns: 1fr;
      gap: 8px;
      padding-top: 14px;
    }
  }
</style>
