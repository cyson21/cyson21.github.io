---
import { ArrowRight } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { careerPeriod, experiences } from '../../data/site';
---

<BaseLayout title="경력" description="기업용 플랫폼 운영 백엔드와 공공·실시간 데이터 파이프라인에서 담당한 문제, 기술적 조치와 검증 범위입니다.">
  <PageIntro title="경력" description="데이터 수집과 API 구현에서 시작해 기업용 플랫폼의 운영 장애, 상태 정합성, 의존성 전환과 테스트 기반 개선으로 책임 범위를 확장했습니다." />

  <section class="section experience-section">
    <div class="container experience-layout">
      <div class="career-summary">
        <div><span>전체 경력</span><strong>{careerPeriod}</strong></div>
        <p>기업용 플랫폼 운영과 데이터 서비스 개발에서 해결한 사례를 경력 순서로 확인할 수 있습니다.</p>
        <a href="/resume/">웹 이력서 보기 <ArrowRight size={17} aria-hidden="true" /></a>
      </div>

      <div class="experience-list">
        {experiences.map((experience) => (
          <article class="experience-entry">
            <header>
              <div>
                <p class="eyebrow">{experience.period}</p>
                <h2>{experience.company}</h2>
                <p class="role">{experience.role}</p>
              </div>
              <p class="context">{experience.context}</p>
            </header>

            <div class="experience-cases" data-count={experience.highlights.length}>
              {experience.highlights.map((highlight) => (
                <section>
                  <div class="case-title"><h3>{highlight.title}</h3></div>
                  <dl>
                    <div><dt>문제</dt><dd>{highlight.problem}</dd></div>
                    <div><dt>조치</dt><dd>{highlight.action}</dd></div>
                    <div><dt>확인</dt><dd>{highlight.result}</dd></div>
                  </dl>
                </section>
              ))}
            </div>

            <div class="experience-stack">
              <span>사용 범위</span>
              <ul class="tag-list">{experience.stack.map((item) => <li class="tag">{item}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .experience-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: start;
  }

  .career-summary {
    display: grid;
    grid-template-columns: 190px minmax(0, 1fr) auto;
    gap: 32px;
    align-items: center;
    padding-block: 20px;
    border-block: 1px solid var(--line-strong);
  }

  .career-summary > div {
    display: grid;
    gap: 4px;
  }

  .career-summary span {
    color: var(--blue);
    font-size: var(--text-label);
    font-weight: 780;
  }

  .career-summary strong {
    font-family: var(--mono);
    font-size: var(--text-body);
  }

  .career-summary > p {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .career-summary a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 5px;
    font-size: 16px;
    font-weight: 900;
  }

  .experience-list {
    display: grid;
    gap: 64px;
  }

  .experience-entry header {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 1fr);
    gap: 44px;
    align-items: end;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--ink);
  }

  .experience-entry h2 {
    font-size: var(--text-h2);
  }

  .role {
    margin-top: 8px;
    color: var(--ink-soft);
    font-weight: 800;
  }

  .context {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .experience-cases {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-left: 1px solid var(--line-strong);
  }

  .experience-cases section {
    padding: 24px;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
  }

  .case-title {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .case-title h3 {
    font-size: var(--text-h3);
  }

  .experience-cases dl {
    display: grid;
    gap: 14px;
    margin: 22px 0 0;
  }

  .experience-cases dl > div {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 10px;
  }

  .experience-cases dt {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .experience-cases dd {
    margin: 0;
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .experience-stack {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 18px;
    padding-top: 20px;
  }

  .experience-stack > span {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  @media (max-width: 959px) {
    .career-summary {
      grid-template-columns: 160px minmax(0, 1fr);
    }

    .career-summary a {
      grid-column: 2;
    }
  }

  @media (min-width: 960px) {
    .experience-cases[data-count='3'] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 639px) {
    .experience-section {
      padding-block: 48px;
    }

    .experience-layout {
      gap: 30px;
    }

    .career-summary {
      grid-template-columns: 1fr;
      gap: 12px;
      padding-top: 12px;
    }

    .career-summary a {
      grid-column: 1;
    }

    .experience-list {
      gap: 48px;
    }

    .experience-entry header,
    .experience-cases {
      grid-template-columns: 1fr;
    }

    .experience-entry header {
      gap: 14px;
      padding-bottom: 18px;
    }

    .experience-cases section {
      padding: 20px;
    }

    .experience-cases dl {
      gap: 10px;
      margin-top: 15px;
    }

    .experience-stack {
      grid-template-columns: 1fr;
      gap: 8px;
      padding-top: 14px;
    }
  }
</style>
