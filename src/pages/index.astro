---
import { getCollection } from 'astro:content';
import { ArrowRight, ArrowUpRight, Download, Mail } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import VerificationSignal from '../components/VerificationSignal.astro';
import ProjectRow from '../components/ProjectRow.astro';
import SystemMap from '../components/SystemMap.astro';
import { capabilities, experiences, profile } from '../data/site';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((project) => project.data.featured);
const homeSignals = [
  projects.find((project) => project.id === 'stockrush')?.data.signals[0],
  projects.find((project) => project.id === 'member-event-consistency')?.data.signals[0],
  projects.find((project) => project.id === 'enterprise-policy-rag')?.data.signals[1],
].filter((signal): signal is NonNullable<typeof signal> => Boolean(signal));
---

<BaseLayout title="손찬양" description="상태 정합성, 장애 복구와 데이터 흐름을 코드와 재현 가능한 테스트 근거로 설명하는 Java/Spring 백엔드 개발자 손찬양의 포트폴리오입니다.">
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <div class="hero-person">
          <img src="/media/profile.png" alt="손찬양 프로필 사진" width="112" height="112" />
          <div>
            <p class="hero-role">Java / Spring Backend Engineer</p>
            <p class="availability"><span aria-hidden="true"></span>Seoul · Backend systems</p>
          </div>
        </div>
        <h1>손찬양</h1>
        <p class="hero-statement">{profile.statement}</p>
        <div class="button-row hero-actions">
          <a class="button" href="/resume/">웹 이력서 <ArrowRight size={18} aria-hidden="true" /></a>
          <a class="button button--secondary" href={profile.resumePath}>PDF <Download size={17} aria-hidden="true" /></a>
          <a class="button button--text" href={profile.github} target="_blank" rel="noreferrer" aria-label="손찬양 GitHub 프로필 새 창에서 열기">GitHub <ArrowUpRight size={17} aria-hidden="true" /></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="experience-title">
    <div class="container">
      <div class="section-heading section-heading--indexed experience-heading">
        <span class="section-number">01</span>
        <div>
          <h2 id="experience-title">경력</h2>
          <p class="section-deck">실무에서 맡은 역할과 책임 범위입니다.</p>
        </div>
        <div>
          <p class="lede">2021년부터 공공·실시간 데이터 서비스와 기업용 플랫폼의 백엔드를 개발·운영했습니다.</p>
          <a class="section-link" href="/experience/">경력 상세 보기 <ArrowRight size={18} aria-hidden="true" /></a>
        </div>
      </div>
      <ol class="career-list">
        {experiences.map((experience) => (
          <li>
            <time>{experience.period}</time>
            <div><strong>{experience.company}</strong><span>{experience.role}</span><p>{experience.context}</p></div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section id="featured-projects" class="section" aria-labelledby="featured-title">
    <div class="container">
      <div class="section-heading section-heading--indexed">
        <span class="section-number">02</span>
        <div>
          <h2 id="featured-title">대표 프로젝트</h2>
          <p class="section-deck">실무에서 마주친 문제를 별도 시스템으로 확장해 검증했습니다.</p>
        </div>
        <div>
          <p class="lede">분산 상태, 동시 요청, 접근 제어처럼 장애 시 영향이 큰 조건을 구현과 테스트 근거로 정리했습니다.</p>
          <a class="section-link" href="/projects/">6개 프로젝트 전체 보기 <ArrowRight size={18} aria-hidden="true" /></a>
        </div>
      </div>
      <div class="project-list">
        {featured.map((project, index) => <ProjectRow project={project} index={index + 1} compact />)}
      </div>
      <div class="project-map">
        <div class="project-map-heading">
          <h3>여섯 프로젝트의 문제 지도</h3>
          <p>각 프로젝트가 보호하는 상태와 실패 지점을 한 흐름으로 연결했습니다.</p>
        </div>
        <SystemMap />
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="proof-title">
    <div class="container">
      <div class="section-heading section-heading--indexed">
        <span class="section-number">03</span>
        <div>
          <h2 id="proof-title">프로젝트 검증 결과</h2>
          <p class="section-deck">프로젝트마다 핵심 실패 조건을 재현했습니다.</p>
        </div>
        <p class="lede">중복 이벤트, 동시 요청, 권한 없는 검색을 테스트 입력으로 재현해 저장 결과와 응답을 확인했습니다.</p>
      </div>
      <div class="signal-grid">
        {homeSignals.map((signal) => <VerificationSignal {...signal} />)}
      </div>
    </div>
  </section>

  <section class="section capabilities" aria-labelledby="capability-title">
    <div class="container">
      <div class="section-heading section-heading--indexed">
        <span class="section-number">04</span>
        <div>
          <h2 id="capability-title">문제 해결 방식</h2>
          <p class="section-deck">재현하고 경계를 좁힌 뒤 테스트로 고정합니다.</p>
        </div>
        <p class="lede">로그·API·DB 상태로 재현 조건을 찾고, 저장 규칙과 외부 의존성의 변경 범위를 좁힌 뒤 정상·차단 경로를 회귀 테스트로 고정합니다.</p>
      </div>
      <div class="capability-grid">
        {capabilities.map((item) => (
          <article>
            <span>{item.id}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <code>{item.signal}</code>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="contact-band">
    <div class="container contact-inner">
      <div><h2>이력서와 전체 프로젝트 보기</h2><p>경력 요약은 이력서에서, 설계와 검증 근거는 프로젝트 상세에서 확인할 수 있습니다.</p></div>
      <div class="button-row">
        <a class="button" href="/resume/">웹 이력서 <ArrowRight size={17} aria-hidden="true" /></a>
        <a class="button button--secondary" href={profile.resumePath}>PDF <Download size={17} aria-hidden="true" /></a>
        <a class="button button--text" href={`mailto:${profile.email}`}>이메일 <Mail size={17} aria-hidden="true" /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 56px 64px;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .hero-inner {
    display: block;
  }

  .hero-copy {
    display: grid;
    max-width: 1080px;
    min-width: 0;
    grid-template-areas:
      "person statement"
      "name statement"
      ". actions";
    grid-template-columns: minmax(270px, 0.72fr) minmax(0, 1.28fr);
    gap: 16px 64px;
    align-items: start;
  }

  .hero-person {
    grid-area: person;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .hero-person img {
    width: 92px;
    height: 92px;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    object-fit: cover;
    filter: grayscale(15%);
  }

  .hero-role {
    margin-bottom: 6px;
    color: var(--blue);
    font-size: 0.96rem;
    font-weight: 780;
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--ink-soft);
    font-family: var(--mono);
    font-size: 0.82rem;
  }

  .availability span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
  }

  .hero h1 {
    grid-area: name;
    font-size: 3.65rem;
  }

  .hero-statement {
    grid-area: statement;
    max-width: 800px;
    margin-top: 6px;
    color: var(--ink-soft);
    font-size: 1.22rem;
    font-weight: 580;
    line-height: 1.7;
  }

  .hero-actions {
    grid-area: actions;
    margin-top: 4px;
  }

  .signal-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .section-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 6px;
    margin-top: 16px;
    font-size: 0.92rem;
    font-weight: 760;
  }

  .project-map {
    margin-top: 52px;
    padding-top: 30px;
    border-top: 1px solid var(--line-strong);
  }

  .project-map-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 28px;
    margin-bottom: 18px;
  }

  .project-map-heading h3 {
    font-size: 1.35rem;
  }

  .project-map-heading p {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .capabilities {
    border-block: 1px solid #303634;
    background: var(--graphite);
    color: white;
  }

  .capabilities .section-number {
    color: #8fc8b4;
  }

  .capabilities .section-deck,
  .capabilities .lede {
    color: #d1d8d5;
  }

  .capability-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid #4a514e;
    border-left: 1px solid #4a514e;
  }

  .capability-grid article {
    display: grid;
    min-height: 210px;
    grid-template-columns: 42px minmax(0, 1fr);
    align-content: start;
    gap: 12px 18px;
    padding: 26px;
    border-right: 1px solid #4a514e;
    border-bottom: 1px solid #4a514e;
  }

  .capability-grid article > span,
  .capability-grid code {
    color: #8fc8b4;
    font-family: var(--mono);
    font-size: 0.82rem;
  }

  .capability-grid article > span {
    grid-row: 1 / 4;
  }

  .capability-grid article > :not(span) {
    grid-column: 2;
  }

  .capability-grid p {
    color: #bdc5c1;
    font-size: 0.94rem;
  }

  .capability-grid code {
    margin-top: 4px;
    color: #65d6ac;
  }

  .experience-heading {
    margin-bottom: 28px;
  }

  .career-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line-strong);
    border-left: 1px solid var(--line-strong);
    list-style: none;
  }

  .career-list li {
    display: block;
    padding: 26px;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
  }

  .career-list time {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.82rem;
  }

  .career-list div {
    display: grid;
    gap: 6px;
    margin-top: 14px;
  }

  .career-list span,
  .career-list p {
    color: var(--ink-soft);
  }

  .career-list span {
    font-size: 0.9rem;
    font-weight: 720;
  }

  .career-list p {
    margin-top: 10px;
    font-size: 0.94rem;
  }

  .contact-band {
    padding-block: 54px;
    border-top: 3px solid var(--amber);
    background: var(--surface-muted);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .contact-inner h2 {
    font-size: 1.85rem;
  }

  .contact-inner > div:first-child p {
    max-width: 680px;
    margin-top: 9px;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  @media (max-width: 980px) {
    .hero-copy {
      display: block;
      max-width: 800px;
    }

    .hero-person {
      margin-bottom: 20px;
    }

    .hero-statement {
      margin-top: 20px;
    }

    .hero-actions {
      margin-top: 26px;
    }

    .capability-grid {
      grid-template-columns: repeat(2, 1fr);
    }

  }

  @media (max-width: 720px) {
    .hero {
      padding-block: 30px 36px;
    }

    .hero h1 {
      font-size: 2.8rem;
    }

    .hero-statement {
      font-size: 1.12rem;
    }

    .hero-person {
      margin-bottom: 14px;
    }

    .hero-actions {
      margin-top: 18px;
    }

    .signal-grid {
      grid-template-columns: 1fr;
    }

    .contact-inner {
      align-items: stretch;
      grid-template-columns: 1fr;
    }

    .project-map-heading {
      align-items: start;
      flex-direction: column;
      gap: 8px;
    }
  }

  @media (max-width: 560px) {
    .hero-person img {
      width: 66px;
      height: 66px;
    }

    .hero h1 {
      font-size: 2.55rem;
    }

    .capability-grid,
    .career-list {
      grid-template-columns: 1fr;
    }

    .capability-grid article {
      min-height: 0;
    }

    .career-list li {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
