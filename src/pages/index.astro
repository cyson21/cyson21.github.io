---
import { getCollection } from 'astro:content';
import { ArrowRight, ArrowUpRight, Download, Mail } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectRow from '../components/ProjectRow.astro';
import { experiences, profile } from '../data/site';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((project) => project.data.featured);
---

<BaseLayout title="손찬양" description="Java와 Spring으로 기업용 플랫폼을 개발·운영하며 동시성, 장애 복구와 데이터 정합성 문제를 해결한 백엔드 개발자 손찬양의 포트폴리오입니다.">
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <div class="hero-person">
          <img src="/media/profile.png" alt="손찬양 프로필 사진" width="112" height="112" />
          <div>
            <p class="hero-role">Java·Spring 백엔드 개발자</p>
          </div>
        </div>
        <h1>손찬양</h1>
        <p class="hero-statement">{profile.statement}</p>
        <div class="button-row hero-actions">
          <a class="button" href="/resume/">웹 이력서 <ArrowRight size={18} aria-hidden="true" /></a>
          <a class="button button--secondary" href={profile.resumePath}>PDF <Download size={17} aria-hidden="true" /></a>
          <a class="button button--text" href={profile.github} target="_blank" rel="noreferrer" aria-label="손찬양 GitHub 프로필 새 창에서 열기">GitHub <ArrowUpRight size={17} aria-hidden="true" /></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="experience-title">
    <div class="container">
      <div class="section-heading experience-heading">
        <div>
          <h2 id="experience-title">경력</h2>
          <p class="section-deck">회사별 담당 업무와 주요 경험을 정리했습니다.</p>
        </div>
        <div>
          <p class="lede">2021년부터 공공·실시간 데이터 서비스와 기업용 플랫폼의 백엔드를 개발·운영했습니다.</p>
          <a class="section-link" href="/experience/">경력 상세 보기 <ArrowRight size={18} aria-hidden="true" /></a>
        </div>
      </div>
      <ol class="career-list">
        {experiences.map((experience) => (
          <li>
            <time>{experience.period}</time>
            <div><strong>{experience.company}</strong><span>{experience.role}</span><p>{experience.context}</p></div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section id="featured-projects" class="section" aria-labelledby="featured-title">
    <div class="container">
      <div class="section-heading">
        <div>
          <h2 id="featured-title">대표 프로젝트</h2>
          <p class="section-deck">백엔드 설계와 문제 해결 과정을 담은 프로젝트입니다.</p>
        </div>
        <div>
          <p class="lede">동시성, 데이터 정합성, 장애 복구와 접근 제어 문제를 설계하고 해결했습니다.</p>
          <a class="section-link" href="/projects/">6개 프로젝트 전체 보기 <ArrowRight size={18} aria-hidden="true" /></a>
        </div>
      </div>
      <div class="project-list">
        {featured.map((project) => <ProjectRow project={project} compact />)}
      </div>
    </div>
  </section>

  <section class="contact-band">
    <div class="container contact-inner">
      <div><h2>경력 및 프로젝트</h2><p>담당 업무와 프로젝트별 문제 해결 과정을 정리했습니다.</p></div>
      <div class="button-row">
        <a class="button" href="/resume/">웹 이력서 <ArrowRight size={17} aria-hidden="true" /></a>
        <a class="button button--secondary" href={profile.resumePath}>PDF <Download size={17} aria-hidden="true" /></a>
        <a class="button button--text" href={`mailto:${profile.email}`}>이메일 <Mail size={17} aria-hidden="true" /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 56px 64px;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .hero-inner {
    display: block;
  }

  .hero-copy {
    display: grid;
    max-width: 1080px;
    min-width: 0;
    grid-template-areas:
      "person statement"
      "name statement"
      ". actions";
    grid-template-columns: minmax(270px, 0.72fr) minmax(0, 1.28fr);
    gap: 16px 64px;
    align-items: start;
  }

  .hero-person {
    grid-area: person;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .hero-person img {
    width: 92px;
    height: 92px;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    object-fit: cover;
    filter: grayscale(15%);
  }

  .hero-role {
    margin-bottom: 6px;
    color: var(--blue);
    font-size: var(--text-dense);
    font-weight: 780;
  }

  .hero h1 {
    grid-area: name;
    font-size: var(--text-h1);
  }

  .hero-statement {
    grid-area: statement;
    max-width: min(760px, 40ic);
    margin-top: 6px;
    color: var(--ink-soft);
    font-size: var(--text-lede);
    font-weight: 580;
    line-height: 1.6;
  }

  .hero-actions {
    grid-area: actions;
    margin-top: 4px;
  }

  .section-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 6px;
    margin-top: 16px;
    font-size: 16px;
    font-weight: 760;
  }

  .experience-heading {
    margin-bottom: 28px;
  }

  .career-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line-strong);
    list-style: none;
  }

  .career-list li {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 24px;
    padding-block: 24px;
    border-bottom: 1px solid var(--line-strong);
  }

  .career-list time {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
  }

  .career-list div {
    display: grid;
    gap: 6px;
    margin-top: 0;
  }

  .career-list span,
  .career-list p {
    color: var(--ink-soft);
  }

  .career-list span {
    font-size: var(--text-dense);
    font-weight: 720;
  }

  .career-list p {
    margin-top: 10px;
    font-size: var(--text-body);
  }

  .contact-band {
    padding-block: 54px;
    border-top: 3px solid var(--amber);
    background: var(--surface-muted);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .contact-inner h2 {
    font-size: var(--text-h2);
  }

  .contact-inner > div:first-child p {
    max-width: 680px;
    margin-top: 9px;
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  @media (max-width: 959px) {
    .hero-copy {
      display: block;
      max-width: 800px;
    }

    .hero-person {
      margin-bottom: 20px;
    }

    .hero-statement {
      margin-top: 20px;
    }

    .hero-actions {
      margin-top: 26px;
    }

  }

  @media (max-width: 639px) {
    .hero {
      padding-block: 30px 36px;
    }

    .hero-person {
      margin-bottom: 14px;
    }

    .hero-actions {
      margin-top: 18px;
    }

    .contact-inner {
      align-items: stretch;
      grid-template-columns: 1fr;
    }

  }

  @media (max-width: 639px) {
    .hero-person img {
      width: 66px;
      height: 66px;
    }

    .career-list li {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
