---
import { ArrowRight, CodeXml, Download, Mail } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { experiences, profile, skillGroups } from '../../data/site';
---

<BaseLayout title="Resume" description="Java/Spring 백엔드 개발자 손찬양의 웹 이력서입니다. 운영 장애 분석, 상태 정합성, 플랫폼 전환과 데이터 파이프라인 경험을 요약합니다.">
  <PageIntro eyebrow="Resume" title="손찬양 · Backend Engineer" description="기업용 플랫폼의 API와 이벤트 모듈을 개발·운영하며 데이터 정합성, 시간대 경계와 플랫폼 전환 문제를 다뤄 온 백엔드 개발자입니다." />

  <section class="section resume-section">
    <div class="container resume-layout">
      <aside class="resume-sidebar">
        <img src="/media/profile.png" alt="손찬양 프로필 사진" width="220" height="220" />
        <div>
          <p class="eyebrow">Contact</p>
          <a href={`mailto:${profile.email}`}><Mail size={16} aria-hidden="true" /> {profile.email}</a>
          <a href={profile.github} target="_blank" rel="noreferrer"><CodeXml size={16} aria-hidden="true" /> github.com/cyson21</a>
        </div>
        <div class="button-stack">
          <a class="button" href={profile.resumePath}><Download size={17} aria-hidden="true" /> PDF 다운로드</a>
          <a class="button button--secondary" href="/projects/">프로젝트 보기 <ArrowRight size={17} aria-hidden="true" /></a>
        </div>
        <p class="updated">UPDATED {profile.updatedAt}</p>
      </aside>

      <article class="resume-content">
        <section class="resume-summary">
          <p class="eyebrow">Profile</p>
          <h2>요약</h2>
          <p>기업용 플랫폼의 API·이벤트 모듈을 Java와 Spring으로 개발·운영하며 요구사항 분석부터 API·저장소 설계, 구현, 회귀 테스트와 스테이징 검증까지 담당했습니다.</p>
          <p>상태 재검증 규칙, UTC/KST 날짜 경계 오류, AWS SDK v2 전환과 Testcontainers 기반 저장소 테스트 표준화처럼 운영에서 발견한 문제를 재현 가능한 검증 경로로 남깁니다.</p>
        </section>

        <section class="resume-experience">
          <p class="eyebrow">Experience</p>
          <h2>경력</h2>
          {experiences.map((experience) => (
            <div class="resume-job">
              <header><div><h3>{experience.company}</h3><p>{experience.role}</p></div><time>{experience.period}</time></header>
              <p class="job-context">{experience.context}</p>
              <ul>
                {experience.highlights.map((highlight) => <li><strong>{highlight.title}</strong><span>{highlight.action} {highlight.result}</span></li>)}
              </ul>
            </div>
          ))}
        </section>

        <section class="resume-skills">
          <p class="eyebrow">Skills</p>
          <h2>기술</h2>
          <div class="skill-groups">
            {skillGroups.map((group) => (
              <div><h3>{group.label}</h3><ul class="tag-list">{group.items.map((item) => <li class="tag">{item}</li>)}</ul></div>
            ))}
          </div>
        </section>

        <section class="resume-education">
          <p class="eyebrow">Education</p>
          <h2>학력</h2>
          <div><strong>서울과학기술대학교</strong><span>영어영문학 학사 · 2018 졸업</span></div>
        </section>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .resume-layout {
    display: grid;
    grid-template-columns: 250px minmax(0, 1fr);
    gap: 78px;
    align-items: start;
  }

  .resume-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 30px);
    display: grid;
    gap: 26px;
  }

  .resume-sidebar > img {
    width: 190px;
    height: 190px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    object-fit: cover;
  }

  .resume-sidebar > div:not(.button-stack) {
    display: grid;
    gap: 9px;
  }

  .resume-sidebar a:not(.button) {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--ink-soft);
    font-size: 0.76rem;
    font-weight: 750;
  }

  .button-stack {
    display: grid;
    gap: 8px;
  }

  .updated {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.66rem;
  }

  .resume-content {
    min-width: 0;
  }

  .resume-content > section {
    padding-bottom: 70px;
  }

  .resume-content h2 {
    margin-bottom: 28px;
    font-size: 2.15rem;
  }

  .resume-summary > p:not(.eyebrow) {
    max-width: 820px;
    color: var(--ink-soft);
    font-size: 1.02rem;
  }

  .resume-summary > p + p {
    margin-top: 14px;
  }

  .resume-job {
    padding-block: 28px;
    border-top: 1px solid var(--line-strong);
  }

  .resume-job:last-child {
    border-bottom: 1px solid var(--line-strong);
  }

  .resume-job header {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 28px;
  }

  .resume-job h3 {
    font-size: 1.28rem;
  }

  .resume-job header p,
  .resume-job time {
    color: var(--ink-soft);
    font-size: 0.75rem;
  }

  .resume-job time {
    flex: 0 0 auto;
    font-family: var(--mono);
  }

  .job-context {
    margin-top: 16px;
    color: var(--ink-soft);
    font-size: 0.88rem;
  }

  .resume-job ul {
    display: grid;
    gap: 12px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  .resume-job li {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 18px;
    padding-left: 16px;
    border-left: 3px solid var(--blue);
  }

  .resume-job li strong {
    font-size: 0.83rem;
  }

  .resume-job li span {
    color: var(--ink-soft);
    font-size: 0.82rem;
  }

  .skill-groups {
    display: grid;
    gap: 18px;
  }

  .skill-groups > div {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 18px;
    padding-block: 16px;
    border-top: 1px solid var(--line);
  }

  .skill-groups h3 {
    font-size: 0.84rem;
  }

  .resume-education > div {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding-block: 18px;
    border-block: 1px solid var(--line-strong);
  }

  .resume-education span {
    color: var(--ink-soft);
    font-size: 0.84rem;
  }

  @media (max-width: 900px) {
    .resume-layout {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .resume-sidebar {
      position: static;
      grid-template-columns: 150px minmax(0, 1fr);
      gap: 18px 24px;
      align-items: start;
    }

    .resume-sidebar > img {
      width: 150px;
      height: 150px;
      grid-row: 1 / 4;
    }
  }

  @media (max-width: 620px) {
    :global(.page-intro.page-intro) {
      padding-block: 36px 32px;
    }

    :global(.page-intro .intro-grid) {
      gap: 14px;
    }

    .resume-section {
      padding-block: 36px;
    }

    .resume-layout {
      gap: 34px;
    }

    .resume-sidebar {
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 12px 18px;
    }

    .resume-sidebar > img {
      width: 96px;
      height: 96px;
      grid-row: 1 / 3;
    }

    .resume-sidebar > div:not(.button-stack) {
      grid-column: 2;
      gap: 5px;
    }

    .resume-sidebar a:not(.button) {
      font-size: 0.7rem;
    }

    .button-stack {
      grid-column: 1 / -1;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 7px;
    }

    .button-stack .button {
      min-height: 40px;
      padding: 7px 9px;
      font-size: 0.76rem;
    }

    .updated {
      grid-column: 2;
      grid-row: 2;
      align-self: end;
    }

    .resume-content > section {
      padding-bottom: 42px;
    }

    .resume-content h2 {
      margin-bottom: 18px;
      font-size: 1.75rem;
    }

    .resume-summary > p:not(.eyebrow) {
      font-size: 0.94rem;
    }

    .resume-job {
      padding-block: 20px;
    }

    .resume-job header {
      gap: 12px;
    }

    .job-context {
      margin-top: 10px;
      font-size: 0.84rem;
    }

    .resume-job ul {
      gap: 10px;
      margin-top: 16px;
    }

    .resume-education > div {
      align-items: start;
      flex-direction: column;
    }

    .resume-job li,
    .skill-groups > div {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .resume-job li {
      padding-left: 12px;
    }

    .skill-groups {
      gap: 8px;
    }

    .skill-groups > div {
      padding-block: 12px;
    }
  }

  @media (max-width: 430px) {
    .resume-job header {
      align-items: start;
      flex-direction: column;
      gap: 5px;
    }

    .button-stack {
      grid-template-columns: 1fr;
    }
  }
</style>
