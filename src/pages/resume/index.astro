---
import { ArrowRight, ArrowUpRight, Download, Mail } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { experiences, profile, resumeSummary, skillGroups } from '../../data/site';

const [currentExperience, ...previousExperiences] = experiences;
if (!currentExperience) {
  throw new Error('웹 이력서에는 현재 경력 항목이 필요합니다.');
}
---

<BaseLayout title="이력서" description="Java·Spring 백엔드 개발자 손찬양의 웹 이력서입니다. 플랫폼 API 개발·운영과 데이터 서비스 경험을 요약합니다.">
  <PageIntro title="손찬양" description={resumeSummary[0]} />

  <section class="section resume-section">
    <div class="container resume-layout">
      <section class="resume-summary">
        <h2>요약</h2>
        <p>{resumeSummary[1]}</p>
        <p>이전에는 공공·실시간 데이터를 수집·가공하고 REST API와 예측 결과 연동 기능을 개발했으며, Docker 기반 배포·운영도 담당했습니다.</p>
      </section>

      <section class="resume-experience resume-experience--current" aria-labelledby="resume-experience-title">
        <h2 id="resume-experience-title">경력</h2>
        <div class="resume-job resume-job--current">
          <header><div><h3>{currentExperience.company}</h3><p>{currentExperience.role}</p></div><time>{currentExperience.period}</time></header>
          <p class="job-context">{currentExperience.context}</p>
          <ul>
            {currentExperience.responsibilities.map((responsibility) => <li><strong>{responsibility.title}</strong><span>{responsibility.description}</span></li>)}
          </ul>
        </div>
      </section>

      <aside class="resume-sidebar">
        <img src="/media/profile.png" alt="손찬양 프로필 사진" width="220" height="220" />
        <div class="resume-contact">
          <p class="eyebrow">연락처</p>
          <a href={`mailto:${profile.email}`}><Mail size={16} aria-hidden="true" /> {profile.email}</a>
          <a href={profile.github} target="_blank" rel="noreferrer" aria-label="손찬양 GitHub 프로필 새 창에서 열기"><ArrowUpRight size={16} aria-hidden="true" /> github.com/cyson21</a>
        </div>
        <div class="button-stack">
          <a class="button" href={profile.resumePath}><Download size={17} aria-hidden="true" /> PDF 다운로드</a>
          <a class="button button--secondary" href="/projects/">프로젝트 보기 <ArrowRight size={17} aria-hidden="true" /></a>
        </div>
      </aside>

      <section class="resume-experience resume-experience--previous" aria-labelledby="resume-experience-title">
        {previousExperiences.map((experience) => (
          <div class="resume-job resume-job--previous">
            <header><div><h3>{experience.company}</h3><p>{experience.role}</p></div><time>{experience.period}</time></header>
            <p class="job-context">{experience.context}</p>
            <ul>
              {experience.responsibilities.map((responsibility) => <li><strong>{responsibility.title}</strong><span>{responsibility.description}</span></li>)}
            </ul>
          </div>
        ))}
      </section>

      <section class="resume-skills">
        <h2>기술 스택</h2>
        <div class="skill-groups">
          {skillGroups.map((group) => (
            <div><p class="skill-label">{group.label}</p><ul class="tag-list">{group.items.map((item) => <li class="tag">{item}</li>)}</ul></div>
          ))}
        </div>
      </section>

      <section class="resume-education">
        <h2>학력</h2>
        <div><strong>서울과학기술대학교</strong><span>영어영문학 학사 · 2018 졸업</span></div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .resume-layout {
    display: grid;
    grid-template-columns: minmax(220px, 240px) minmax(0, 1fr);
    column-gap: clamp(24px, 2.2vw, 32px);
    align-items: start;
  }

  .resume-layout > section {
    grid-column: 2;
    min-width: 0;
  }

  .resume-summary {
    margin-bottom: 42px;
    padding: clamp(20px, 2.4vw, 28px);
  }

  .resume-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 30px);
    display: grid;
    grid-column: 1;
    grid-row: 1 / span 5;
    gap: 20px;
    padding: 18px;
  }

  .resume-sidebar > img {
    justify-self: center;
    width: 190px;
    height: 190px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    object-fit: cover;
  }

  .resume-contact {
    display: grid;
    gap: 9px;
  }

  .resume-sidebar a:not(.button) {
    display: flex;
    min-height: 44px;
    min-width: 0;
    align-items: center;
    gap: 7px;
    color: var(--ink-soft);
    font-size: var(--text-dense);
    font-weight: 750;
    overflow-wrap: anywhere;
  }

  .button-stack {
    display: grid;
    gap: 8px;
  }

  .resume-layout > section:not(.resume-summary) {
    padding-top: 22px;
    padding-bottom: 56px;
    border-top: 1px solid var(--line-strong);
  }

  .resume-layout h2 {
    margin-bottom: 28px;
    font-size: var(--text-h2);
  }

  .resume-summary > p:not(.eyebrow) {
    max-width: min(760px, 40ic);
    color: var(--ink-soft);
    font-size: var(--text-body);
  }

  .resume-summary > p + p {
    margin-top: 14px;
  }

  .resume-experience--current {
    padding-bottom: 0 !important;
  }

  .resume-experience--previous {
    padding-top: 0 !important;
  }

  .resume-job {
    padding-block: 28px;
    border-top: 1px solid var(--line-strong);
  }

  .resume-job:last-child {
    border-bottom: 1px solid var(--line-strong);
  }

  .resume-job header {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 28px;
  }

  .resume-job h3 {
    font-size: var(--text-h3);
  }

  .resume-job header p,
  .resume-job time {
    color: var(--ink-soft);
    font-size: var(--text-label);
  }

  .resume-job time {
    flex: 0 0 auto;
    font-family: var(--mono);
  }

  .job-context {
    margin-top: 16px;
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .resume-job ul {
    display: grid;
    gap: 12px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  .resume-job li {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 18px;
    padding-left: 16px;
    border-left: 3px solid var(--blue);
  }

  .resume-job li strong {
    font-size: var(--text-dense);
  }

  .resume-job li span {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .skill-groups {
    display: grid;
    gap: 18px;
  }

  .skill-groups > div {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 18px;
    padding-block: 16px;
    border-top: 1px solid var(--line);
  }

  .skill-label {
    font-size: var(--text-dense);
    font-weight: 800;
  }

  .resume-education > div {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding-block: 18px;
    border-block: 1px solid var(--line-strong);
  }

  .resume-education span {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  @media (max-width: 959px) {
    .resume-layout {
      grid-template-columns: 1fr;
      column-gap: 0;
    }

    .resume-layout > section {
      grid-column: 1;
    }

    .resume-sidebar {
      position: static;
      grid-column: 1;
      grid-row: auto;
      grid-template-columns: 128px minmax(0, 1fr);
      gap: 14px 22px;
      align-items: start;
      margin: 16px 0 46px;
    }

    .resume-sidebar > img {
      width: 128px;
      height: 128px;
      grid-row: 1 / 3;
    }

    .resume-contact,
    .button-stack {
      grid-column: 2;
    }

    .button-stack {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .resume-experience--previous {
      border-top: 1px solid var(--line-strong);
    }
  }

  @media (min-width: 960px) {
    .resume-sidebar a:not(.button) {
      white-space: nowrap;
    }
  }

  @media (max-width: 639px) {
    .resume-section {
      padding-block: 48px;
    }

    .resume-sidebar {
      grid-template-columns: 88px minmax(0, 1fr);
      gap: 12px 16px;
      margin-block: 10px 38px;
      padding: 14px;
    }

    .resume-sidebar > img {
      width: 88px;
      height: 88px;
      grid-row: 1;
    }

    .resume-contact {
      grid-column: 2;
      gap: 5px;
    }

    .resume-sidebar a:not(.button) {
      font-size: var(--text-label);
    }

    .button-stack {
      grid-column: 1 / -1;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 7px;
    }

    .button-stack .button {
      min-height: 44px;
      padding: 7px 9px;
      font-size: 16px;
    }

    .resume-layout > section:not(.resume-summary) {
      padding-bottom: 42px;
    }

    .resume-layout h2 {
      margin-bottom: 18px;
    }

    .resume-summary {
      margin-bottom: 34px;
      padding: 18px;
    }

    .resume-job {
      margin-block: 12px;
      padding-block: 18px;
    }

    .resume-job header {
      gap: 12px;
    }

    .job-context {
      margin-top: 10px;
      font-size: var(--text-dense);
    }

    .resume-job ul {
      gap: 10px;
      margin-top: 16px;
    }

    .resume-education > div {
      align-items: start;
      flex-direction: column;
    }

    .resume-job li,
    .skill-groups > div {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .resume-job li {
      padding-left: 12px;
    }

    .skill-groups {
      gap: 8px;
    }

    .skill-groups > div {
      padding-block: 12px;
    }

    .resume-job header {
      align-items: start;
      flex-direction: column;
      gap: 5px;
    }
  }

  @media (max-width: 359px) {
    .resume-sidebar {
      grid-template-columns: 1fr;
    }

    .resume-sidebar > img {
      grid-column: 1;
      width: 80px;
      height: 80px;
      justify-self: start;
    }

    .resume-contact {
      grid-column: 1;
    }

    .button-stack {
      grid-column: 1;
      grid-template-columns: 1fr;
    }
  }
</style>
