---
import { ArrowRight, ArrowUpRight, Download, Mail } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { experiences, profile, skillGroups } from '../../data/site';
---

<BaseLayout title="이력서" description="Java·Spring 백엔드 개발자 손찬양의 웹 이력서입니다. 운영 장애 분석, 상태 정합성, 플랫폼 전환과 데이터 파이프라인 경험을 요약합니다.">
  <PageIntro title="손찬양" description="Java와 Spring으로 기업용 플랫폼 API를 개발·운영하는 백엔드 개발자입니다." />

  <section class="section resume-section">
    <div class="container resume-layout">
      <article class="resume-content">
        <section class="resume-summary">
          <h2>요약</h2>
          <p>기업용 플랫폼 API와 이벤트 기능을 개발·운영하며 요구사항 분석부터 데이터 모델 설계, 기능 구현과 회귀 테스트까지 맡고 있습니다. 운영 중 발생한 상태 충돌과 시간대 오류를 재현해 수정했고, 구형 AWS SDK와 DB 통합 테스트 환경을 정비했습니다.</p>
        </section>

        <section class="resume-experience">
          <h2>경력</h2>
          {experiences.map((experience) => (
            <div class="resume-job">
              <header><div><h3>{experience.company}</h3><p>{experience.role}</p></div><time>{experience.period}</time></header>
              <p class="job-context">{experience.context}</p>
              <ul>
                {experience.highlights.map((highlight) => <li><strong>{highlight.title}</strong><span>{highlight.action} {highlight.result}</span></li>)}
              </ul>
            </div>
          ))}
        </section>

        <section class="resume-skills">
          <h2>기술 스택</h2>
          <div class="skill-groups">
            {skillGroups.map((group) => (
              <div><p class="skill-label">{group.label}</p><ul class="tag-list">{group.items.map((item) => <li class="tag">{item}</li>)}</ul></div>
            ))}
          </div>
        </section>

        <section class="resume-education">
          <h2>학력</h2>
          <div><strong>서울과학기술대학교</strong><span>영어영문학 학사 · 2018 졸업</span></div>
        </section>
      </article>

      <aside class="resume-sidebar">
        <img src="/media/profile.png" alt="손찬양 프로필 사진" width="220" height="220" />
        <div>
          <p class="eyebrow">연락처</p>
          <a href={`mailto:${profile.email}`}><Mail size={16} aria-hidden="true" /> {profile.email}</a>
          <a href={profile.github} target="_blank" rel="noreferrer" aria-label="손찬양 GitHub 프로필 새 창에서 열기"><ArrowUpRight size={16} aria-hidden="true" /> github.com/cyson21</a>
        </div>
        <div class="button-stack">
          <a class="button" href={profile.resumePath}><Download size={17} aria-hidden="true" /> PDF 다운로드</a>
          <a class="button button--secondary" href="/projects/">프로젝트 보기 <ArrowRight size={17} aria-hidden="true" /></a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .resume-layout {
    display: grid;
    grid-template-columns: 250px minmax(0, 1fr);
    gap: 78px;
    align-items: start;
  }

  .resume-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 30px);
    display: grid;
    grid-column: 1;
    grid-row: 1;
    gap: 26px;
  }

  .resume-sidebar > img {
    width: 190px;
    height: 190px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    object-fit: cover;
  }

  .resume-sidebar > div:not(.button-stack) {
    display: grid;
    gap: 9px;
  }

  .resume-sidebar a:not(.button) {
    display: flex;
    min-height: 44px;
    min-width: 0;
    align-items: center;
    gap: 7px;
    color: var(--ink-soft);
    font-size: var(--text-dense);
    font-weight: 750;
    overflow-wrap: anywhere;
  }

  .button-stack {
    display: grid;
    gap: 8px;
  }

  .resume-content {
    grid-column: 2;
    grid-row: 1;
    min-width: 0;
  }

  .resume-content > section {
    padding-top: 22px;
    padding-bottom: 70px;
    border-top: 1px solid var(--line-strong);
  }

  .resume-content h2 {
    margin-bottom: 28px;
    font-size: var(--text-h2);
  }

  .resume-summary > p:not(.eyebrow) {
    max-width: min(760px, 40ic);
    color: var(--ink-soft);
    font-size: var(--text-body);
  }

  .resume-summary > p + p {
    margin-top: 14px;
  }

  .resume-job {
    padding-block: 28px;
    border-top: 1px solid var(--line-strong);
  }

  .resume-job:last-child {
    border-bottom: 1px solid var(--line-strong);
  }

  .resume-job header {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 28px;
  }

  .resume-job h3 {
    font-size: var(--text-h3);
  }

  .resume-job header p,
  .resume-job time {
    color: var(--ink-soft);
    font-size: var(--text-label);
  }

  .resume-job time {
    flex: 0 0 auto;
    font-family: var(--mono);
  }

  .job-context {
    margin-top: 16px;
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .resume-job ul {
    display: grid;
    gap: 12px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  .resume-job li {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 18px;
    padding-left: 16px;
    border-left: 3px solid var(--blue);
  }

  .resume-job li strong {
    font-size: var(--text-dense);
  }

  .resume-job li span {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .skill-groups {
    display: grid;
    gap: 18px;
  }

  .skill-groups > div {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 18px;
    padding-block: 16px;
    border-top: 1px solid var(--line);
  }

  .skill-label {
    font-size: var(--text-dense);
    font-weight: 800;
  }

  .resume-education > div {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding-block: 18px;
    border-block: 1px solid var(--line-strong);
  }

  .resume-education span {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  @media (max-width: 959px) {
    .resume-layout {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .resume-sidebar {
      position: static;
      grid-column: 1;
      grid-row: auto;
      grid-template-columns: 150px minmax(0, 1fr);
      gap: 18px 24px;
      align-items: start;
    }

    .resume-sidebar > img {
      width: 150px;
      height: 150px;
      grid-row: 1 / 4;
    }

    .resume-content {
      grid-column: 1;
      grid-row: auto;
    }
  }

  @media (max-width: 639px) {
    .resume-section {
      padding-block: 48px;
    }

    .resume-layout {
      gap: 34px;
    }

    .resume-sidebar {
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 12px 18px;
    }

    .resume-sidebar > img {
      width: 96px;
      height: 96px;
      grid-row: 1 / 3;
    }

    .resume-sidebar > div:not(.button-stack) {
      grid-column: 2;
      gap: 5px;
    }

    .resume-sidebar a:not(.button) {
      font-size: var(--text-label);
    }

    .button-stack {
      grid-column: 1 / -1;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 7px;
    }

    .button-stack .button {
      min-height: 44px;
      padding: 7px 9px;
      font-size: 16px;
    }

    .resume-content > section {
      padding-bottom: 42px;
    }

    .resume-content h2 {
      margin-bottom: 18px;
    }

    .resume-job {
      padding-block: 20px;
    }

    .resume-job header {
      gap: 12px;
    }

    .job-context {
      margin-top: 10px;
      font-size: var(--text-dense);
    }

    .resume-job ul {
      gap: 10px;
      margin-top: 16px;
    }

    .resume-education > div {
      align-items: start;
      flex-direction: column;
    }

    .resume-job li,
    .skill-groups > div {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .resume-job li {
      padding-left: 12px;
    }

    .skill-groups {
      gap: 8px;
    }

    .skill-groups > div {
      padding-block: 12px;
    }
  }

  @media (max-width: 639px) {
    .resume-job header {
      align-items: start;
      flex-direction: column;
      gap: 5px;
    }

    .button-stack {
      grid-template-columns: 1fr;
    }
  }
</style>
