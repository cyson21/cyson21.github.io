---
import { getCollection } from 'astro:content';
import { experiences, profile, skillGroups } from '../../data/site';

const projects = await getCollection('projects');
const [primaryExperience, previousExperience] = experiences;
if (!primaryExperience || !previousExperience) {
  throw new Error('이력서 출력에는 경력 항목이 두 개 이상 필요합니다.');
}
const projectMap = new Map(projects.map((project) => [project.id, project]));
const selectedIds = ['stockrush', 'member-event-consistency', 'enterprise-policy-rag', 'ai-gateway', 'cdc-data-platform'];
const representativeProjects = selectedIds
  .map((id) => projectMap.get(id))
  .filter((project): project is NonNullable<typeof project> => Boolean(project));
const featuredProjects = representativeProjects.slice(0, 3);
const additionalProjects = representativeProjects.slice(3);
const verificationLabels = {
  unit: '단위 테스트',
  integration: '통합 테스트',
  'container-smoke': '컨테이너 테스트',
  'static-demo': '정적 데모',
  'live-demo': '공개 데모',
  cloud: '클라우드 환경',
} as const;
const firstVerificationLabel = (project: (typeof representativeProjects)[number]) => {
  const verification = project.data.verification.at(0);
  return verification ? verificationLabels[verification.layer] : '테스트 기록';
};
const firstSignalResult = (project: (typeof representativeProjects)[number]) => {
  const signal = project.data.signals.at(0);
  if (!signal) throw new Error(`${project.id} 프로젝트에 테스트 결과가 없습니다.`);
  return signal.result;
};
---

<!doctype html>
<html lang="ko-KR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>손찬양 이력서</title>
  </head>
  <body>
    <main>
      <section class="sheet sheet--first" aria-label="이력서 1페이지">
        <header class="masthead">
          <div>
            <h1>{profile.name}</h1>
            <p class="role-line">Java·Spring 백엔드 개발자</p>
            <p class="statement">{profile.statement}</p>
          </div>
          <img src="/media/profile.png" alt="손찬양 프로필 사진" width="116" height="116" />
        </header>

        <div class="contact-row">
          <a href={`mailto:${profile.email}`}>{profile.email}</a>
          <a href={profile.github}>github.com/cyson21</a>
          <span>서울</span>
        </div>

        <section class="summary block">
          <h2>요약</h2>
          <div><strong>기업용 플랫폼 API와 이벤트 기능을 Java·Spring으로 개발·운영했습니다.</strong><p>저장 전 상태 충돌, UTC/KST 날짜 경계와 구형 AWS SDK 문제를 재현해 수정하고 회귀 테스트를 보강했습니다.</p></div>
        </section>

        <section class="focus-list block" aria-label="핵심 역량">
          <h2>핵심 역량</h2>
          <div>
            <article><strong>운영 장애 분석</strong><p>로그·API 흐름·DB 상태를 함께 추적해 재현 조건과 수정 범위를 좁힙니다.</p></article>
            <article><strong>상태 정합성</strong><p>트랜잭션·멱등 처리·조건부 갱신으로 중복과 상태 역전을 방지합니다.</p></article>
            <article><strong>플랫폼 전환</strong><p>구형 의존성을 교체하고 모듈 테스트와 빌드 산출물로 변경 범위를 확인합니다.</p></article>
          </div>
        </section>

        <section class="experience block">
          <div class="section-title"><h2>경력</h2></div>
          <article class="job">
            <header>
              <div><h3>{primaryExperience.company}</h3><p>{primaryExperience.role}</p></div>
              <time>{primaryExperience.period}</time>
            </header>
            <p class="context">{primaryExperience.context}</p>
            <div class="highlight-list">
              {primaryExperience.highlights.map((highlight) => (
                <div><strong>{highlight.title}</strong><p>{highlight.action} {highlight.result}</p></div>
              ))}
            </div>
          </article>
        </section>

        <footer><span>손찬양 · 이력서</span><span>01 / 02</span></footer>
      </section>

      <section class="sheet" aria-label="이력서 2페이지">
        <header class="page-header"><strong>{profile.name}</strong><span>{profile.role}</span></header>

        <section class="experience block block--second">
          <div class="section-title"><h2>이전 경력</h2></div>
          <article class="job">
            <header>
              <div><h3>{previousExperience.company}</h3><p>{previousExperience.role}</p></div>
              <time>{previousExperience.period}</time>
            </header>
            <p class="context">{previousExperience.context}</p>
            <div class="highlight-list highlight-list--compact">
              {previousExperience.highlights.map((highlight) => (
                <div><strong>{highlight.title}</strong><p>{highlight.action} {highlight.result}</p></div>
              ))}
            </div>
          </article>
        </section>

        <section class="projects block">
          <div class="section-title"><h2>대표 프로젝트</h2></div>
          <div class="project-list">
            {featuredProjects.map((project) => (
              <article>
                <h3>{project.data.name}</h3>
                <em>{project.data.eyebrow}</em>
                <p>{project.data.summary}</p>
                <small>{firstVerificationLabel(project)} · {firstSignalResult(project)}</small>
              </article>
            ))}
          </div>
          <div class="additional-projects">
            <strong>추가 프로젝트</strong>
            {additionalProjects.map((project) => (
              <span>{project.data.name} · {firstVerificationLabel(project)}</span>
            ))}
          </div>
        </section>

        <div class="lower-grid block">
          <section>
            <div class="section-title"><h2>기술 스택</h2></div>
            <div class="skills">
              {skillGroups.map((group) => <div><strong>{group.label}</strong><p>{group.items.join(' · ')}</p></div>)}
            </div>
          </section>
          <section>
            <div class="section-title"><h2>학력</h2></div>
            <div class="education"><strong>서울과학기술대학교</strong><p>영어영문학 학사</p><span>2018 졸업</span></div>
          </section>
        </div>

        <footer><a href={profile.github}>포트폴리오 · github.com/cyson21</a><span>02 / 02</span></footer>
      </section>
    </main>
  </body>
</html>

<style is:global>
  @page { size: A4; margin: 0; }

  * { box-sizing: border-box; }

  html,
  body { margin: 0; background: #dfe3e1; color: #171a1d; font-family: Pretendard, "Noto Sans KR", "Apple SD Gothic Neo", Arial, sans-serif; letter-spacing: 0; }

  body { font-size: 10pt; line-height: 1.55; }

  a { color: inherit; text-decoration: none; }

  main { display: grid; justify-content: center; gap: 10mm; padding-block: 10mm; }

  .sheet { position: relative; width: 210mm; height: 297mm; overflow: hidden; padding: 14mm 15mm 24mm; background: #fff; break-after: page; }
  .sheet:last-child { break-after: auto; }

  h1,
  h2,
  h3,
  p { margin: 0; overflow-wrap: normal; word-break: keep-all; }

  h1 { margin-top: 1.5mm; font-size: 31pt; line-height: 1.05; }
  h2 { font-size: 15pt; line-height: 1.25; }
  h3 { font-size: 11.2pt; line-height: 1.25; }

  .label { color: #1c5d99; font-family: "SFMono-Regular", Consolas, monospace; font-size: 8.5pt; font-weight: 800; letter-spacing: 0.06em; }
  .block { margin-top: 8mm; }

  .masthead { display: grid; grid-template-columns: 1fr 27mm; gap: 8mm; align-items: center; }
  .masthead img { width: 27mm; height: 27mm; border: 0.3mm solid #818b86; border-radius: 1.4mm; object-fit: cover; }
  .statement { max-width: 132mm; margin-top: 2mm; color: #4d5752; font-size: 10pt; font-weight: 650; line-height: 1.5; }
  .role-line { margin-top: 1.5mm; color: #1c5d99; font-size: 9.5pt; font-weight: 800; }

  .contact-row { display: flex; gap: 7mm; margin-top: 4mm; padding-block: 3mm; border-block: 0.25mm solid #cbd2cd; color: #4d5752; font-family: "SFMono-Regular", Consolas, monospace; font-size: 8.5pt; font-weight: 700; }

  .summary { display: grid; grid-template-columns: 29mm 1fr; gap: 6mm; }
  .summary > div > strong { font-size: 10pt; line-height: 1.5; }
  .summary > div > p { margin-top: 1.8mm; color: #4d5752; font-size: 10pt; line-height: 1.55; }

  .focus-list { display: grid; grid-template-columns: 29mm 1fr; gap: 6mm; padding-block: 4mm; border-block: 0.3mm solid #818b86; }
  .focus-list > h2 { padding-top: 0.5mm; }
  .focus-list > div { display: grid; gap: 1.5mm; }
  .focus-list article { display: grid; grid-template-columns: 29mm 1fr; gap: 4mm; }
  .focus-list strong { font-size: 9.5pt; }
  .focus-list p { color: #4d5752; font-size: 9.5pt; line-height: 1.5; }

  .section-title { margin-bottom: 2.5mm; }

  .job { border-top: 0.4mm solid #171a1d; }
  .job > header { display: flex; justify-content: space-between; gap: 8mm; padding-top: 3mm; }
  .job > header p,
  .job time { margin-top: 0.7mm; color: #4d5752; font-size: 8.5pt; }
  .job time { flex: 0 0 auto; font-family: "SFMono-Regular", Consolas, monospace; }
  .context { margin-top: 2.2mm; color: #4d5752; font-size: 10pt; line-height: 1.55; }
  .highlight-list { display: grid; grid-template-columns: 1fr 1fr; gap: 4.5mm 6mm; margin-top: 4mm; }
  .highlight-list > div { min-height: 0; padding-left: 3.5mm; border-left: 0.8mm solid #1c5d99; }
  .highlight-list strong { font-size: 10pt; }
  .highlight-list p { margin-top: 1mm; color: #4d5752; font-size: 9.5pt; line-height: 1.5; }

  .sheet--first .highlight-list { grid-template-columns: 1fr; gap: 0; }
  .sheet--first .highlight-list > div { display: grid; grid-template-columns: 42mm 1fr; gap: 5mm; padding-block: 4mm; border-bottom: 0.25mm solid #cbd2cd; }
  .sheet--first .highlight-list strong { text-wrap: balance; }
  .sheet--first .highlight-list p { margin-top: 0; }

  footer { position: absolute; right: 15mm; bottom: 14mm; left: 15mm; display: flex; justify-content: space-between; padding-top: 2mm; border-top: 0.25mm solid #cbd2cd; color: #4d5752; font-family: "SFMono-Regular", Consolas, monospace; font-size: 7.5pt; line-height: 1.5; }

  .page-header { display: flex; justify-content: space-between; padding-bottom: 3mm; border-bottom: 0.4mm solid #171a1d; }
  .page-header strong { font-size: 12pt; }
  .page-header span { color: #4d5752; font-family: "SFMono-Regular", Consolas, monospace; font-size: 8.5pt; }
  .block--second { margin-top: 7mm; }
  .highlight-list--compact { grid-template-columns: repeat(3, 1fr); gap: 4mm; }
  .highlight-list--compact > div { min-height: 0; padding-block: 1mm; }

  .project-list { border-top: 0.4mm solid #171a1d; }
  .project-list article { padding-block: 4mm; border-bottom: 0.25mm solid #cbd2cd; }
  .project-list h3 { display: inline; margin-right: 2.4mm; font-size: 11pt; }
  .project-list em { color: #1c5d99; font-size: 8.5pt; font-style: normal; font-weight: 800; }
  .project-list p { margin-top: 1mm; color: #4d5752; font-size: 9.5pt; line-height: 1.5; }
  .project-list small { display: block; margin-top: 0.8mm; color: #187a55; font-size: 8.5pt; font-weight: 750; }
  .additional-projects { display: flex; flex-wrap: wrap; gap: 1.4mm 5mm; padding: 3mm 0; border-bottom: 0.25mm solid #cbd2cd; color: #4d5752; font-size: 8.5pt; }
  .additional-projects strong { color: #171a1d; }

  .lower-grid { display: grid; grid-template-columns: 1.35fr 0.65fr; gap: 10mm; margin-top: 7mm; }
  .lower-grid > section { min-width: 0; }
  .skills { border-top: 0.4mm solid #171a1d; }
  .skills > div { display: grid; grid-template-columns: 34mm 1fr; gap: 3mm; padding-block: 3mm; border-bottom: 0.25mm solid #cbd2cd; }
  .skills strong { font-size: 9.5pt; }
  .skills p { color: #4d5752; font-size: 9.5pt; line-height: 1.5; }
  .education { padding-top: 2.5mm; border-top: 0.4mm solid #171a1d; }
  .education strong { font-size: 10pt; }
  .education p,
  .education span { display: block; margin-top: 1mm; color: #4d5752; font-size: 9.5pt; }

  @media screen {
    .sheet { box-shadow: 0 6mm 14mm rgba(23, 26, 29, 0.12); }
  }

  @media screen and (max-width: 839px) {
    main { display: block; padding: 12px; }
    .sheet {
      width: 100%;
      height: auto;
      min-height: 297mm;
      margin-bottom: 16px;
      overflow: visible;
      padding: 24px 20px 64px;
    }
    .masthead { grid-template-columns: minmax(0, 1fr) 84px; gap: 16px; }
    .masthead > div,
    .summary > div,
    .job > header > div { min-width: 0; }
    .masthead img { width: 84px; height: 84px; }
    .contact-row { flex-wrap: wrap; gap: 8px 20px; }
    .contact-row a { overflow-wrap: anywhere; }
    .summary,
    .focus-list { grid-template-columns: 1fr; gap: 12px; }
    .focus-list article,
    .sheet--first .highlight-list > div { grid-template-columns: 1fr; gap: 6px; }
    .highlight-list,
    .highlight-list--compact,
    .lower-grid { grid-template-columns: 1fr; }
    footer { right: 20px; bottom: 20px; left: 20px; }
  }

  @media print {
    html,
    body { background: #fff; }
    main { display: block; padding: 0; }
    .sheet { box-shadow: none; }
  }
</style>
