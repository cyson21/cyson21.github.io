---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import ProjectRow from '../../components/ProjectRow.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const counts = {
  All: projects.length,
  Backend: projects.filter((project) => project.data.domain === 'Backend').length,
  Data: projects.filter((project) => project.data.domain === 'Data').length,
  AI: projects.filter((project) => project.data.domain === 'AI').length,
};
---

<BaseLayout title="Projects" description="분산 정합성, AI 백엔드, 데이터 플랫폼과 개인화 시스템을 문제, 설계 판단, 코드 근거와 연결 테스트로 설명합니다.">
  <PageIntro eyebrow="Project archive" title="Systems, tested under failure." description="구현 기술을 나열하지 않습니다. 각 프로젝트가 어떤 실패 조건을 다루고, 어떤 규칙으로 상태를 보호하며, 어느 수준까지 검증했는지 같은 순서로 확인할 수 있습니다." />

  <section class="section">
    <div class="container">
      <div class="filter-bar" aria-label="프로젝트 영역 필터">
        <fieldset class="filter-buttons">
          <legend class="visually-hidden">프로젝트 영역</legend>
          {Object.entries(counts).map(([domain, count], index) => (
            <label>
              <input type="radio" name="project-domain" value={domain} data-project-filter checked={index === 0} />
              <span class="filter-option">{domain}<span>{count}</span></span>
            </label>
          ))}
        </fieldset>
        <p id="filter-status" aria-live="polite">전체 {projects.length}개 프로젝트</p>
      </div>

      <div class="project-list" data-project-list>
        {projects.map((project, index) => (
          <div data-project-domain={project.data.domain}>
            <ProjectRow project={project} index={index + 1} />
          </div>
        ))}
      </div>
      <p class="empty-note" data-filter-empty hidden>선택한 영역의 프로젝트가 없습니다.</p>
    </div>
  </section>

  <section class="section section--surface archive-note">
    <div class="container archive-note-grid">
      <h2>검증 수준을<br />분리해서 읽어주세요.</h2>
      <div>
        <p>각 상세 페이지는 unit, integration, container smoke, static demo, live demo와 cloud 증거를 구분합니다. 검증하지 않은 운영 규모나 외부 인프라 결과는 현재 범위에 명시합니다.</p>
        <ul class="tag-list" aria-label="검증 수준">
          <li class="tag">unit</li><li class="tag">integration</li><li class="tag">container-smoke</li><li class="tag">static-demo</li><li class="tag">live-demo</li><li class="tag">cloud</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filters = Array.from(document.querySelectorAll<HTMLInputElement>('[data-project-filter]'));
  const projects = Array.from(document.querySelectorAll<HTMLElement>('[data-project-domain]'));
  const status = document.querySelector<HTMLElement>('#filter-status');
  const empty = document.querySelector<HTMLElement>('[data-filter-empty]');

  filters.forEach((filter) => {
    filter.addEventListener('change', () => {
      if (!filter.checked) return;
      const domain = filter.value || 'All';
      let visible = 0;
      projects.forEach((project) => {
        const show = domain === 'All' || project.dataset.projectDomain === domain;
        project.hidden = !show;
        if (show) visible += 1;
      });
      if (status) status.textContent = domain === 'All' ? `전체 ${visible}개 프로젝트` : `${domain} ${visible}개 프로젝트`;
      if (empty) empty.hidden = visible > 0;
    });
  });
</script>

<style>
  .filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 34px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line-strong);
  }

  .filter-buttons {
    display: flex;
    min-width: 0;
    gap: 5px;
    margin: 0;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--surface-muted);
  }

  .filter-buttons label {
    position: relative;
    display: flex;
  }

  .filter-buttons input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0.001;
  }

  .filter-option {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 7px;
    padding: 7px 12px;
    border: 0;
    border-radius: 3px;
    background: transparent;
    color: var(--ink-soft);
    font-size: 0.78rem;
    font-weight: 850;
    cursor: pointer;
  }

  .filter-buttons input:checked + .filter-option {
    background: var(--surface);
    color: var(--ink);
    box-shadow: 0 1px 4px rgba(23, 26, 29, 0.14);
  }

  .filter-buttons input:focus-visible + .filter-option {
    outline: 3px solid var(--focus);
    outline-offset: 3px;
  }

  .filter-option > span {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.65rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  #filter-status {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.72rem;
  }

  .archive-note-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(340px, 1fr);
    gap: 64px;
    align-items: start;
  }

  .archive-note-grid > div {
    display: grid;
    gap: 22px;
    color: var(--ink-soft);
  }

  @media (max-width: 760px) {
    .filter-bar {
      align-items: stretch;
      flex-direction: column;
    }

    .filter-buttons {
      width: 100%;
      overflow-x: auto;
    }

    .filter-buttons label {
      flex: 1 0 auto;
    }

    .archive-note-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
