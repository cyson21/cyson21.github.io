---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import ProjectRow from '../../components/ProjectRow.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const counts = {
  All: projects.length,
  Backend: projects.filter((project) => project.data.domain === 'Backend').length,
  Data: projects.filter((project) => project.data.domain === 'Data').length,
  AI: projects.filter((project) => project.data.domain === 'AI').length,
};
const domainLabels: Record<string, string> = { All: '전체', Backend: '백엔드', Data: '데이터', AI: 'AI' };
---

<BaseLayout title="프로젝트" description="분산 정합성, AI 백엔드, 데이터 플랫폼과 개인화 시스템의 실패 조건, 기술 선택, 주요 구현과 테스트 결과를 정리했습니다.">
  <PageIntro title="프로젝트" description="중복 요청, 메시지 지연, 접근 권한과 데이터 재처리 조건을 다룬 6개 프로젝트를 정리했습니다." />

  <section class="section">
    <div class="container">
      <div class="filter-bar" aria-label="프로젝트 영역 필터">
        <fieldset class="filter-buttons">
          <legend class="visually-hidden">프로젝트 영역</legend>
          {Object.entries(counts).map(([domain, count], index) => (
            <label>
              <input type="radio" name="project-domain" value={domain} data-project-filter checked={index === 0} />
              <span class="filter-option">{domainLabels[domain]}<span>{count}</span></span>
            </label>
          ))}
        </fieldset>
        <p id="filter-status" aria-live="polite">전체 {projects.length}개 프로젝트</p>
      </div>

      <div class="project-list" data-project-list>
        {projects.map((project) => (
          <div data-project-domain={project.data.domain}>
            <ProjectRow project={project} headingLevel={2} />
          </div>
        ))}
      </div>
      <p class="empty-note" data-filter-empty hidden>선택한 영역의 프로젝트가 없습니다.</p>
    </div>
  </section>

  <section class="section section--surface archive-note">
    <div class="container archive-note-grid">
      <div><h2>구현·확인 범위</h2></div>
      <div>
        <p>프로젝트마다 직접 구현한 범위와 결과를 확인한 환경을 구분했습니다. 운영 규모의 부하와 외부 인프라가 포함되지 않은 경우도 상세 페이지에 명시했습니다.</p>
        <ul class="tag-list" aria-label="구현·확인 환경">
          <li class="tag">단위 테스트</li><li class="tag">통합 테스트</li><li class="tag">컨테이너</li><li class="tag">정적 데모</li><li class="tag">공개 데모</li><li class="tag">클라우드</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filters = Array.from(document.querySelectorAll<HTMLInputElement>('[data-project-filter]'));
  const projects = Array.from(document.querySelectorAll<HTMLElement>('[data-project-domain]'));
  const status = document.querySelector<HTMLElement>('#filter-status');
  const empty = document.querySelector<HTMLElement>('[data-filter-empty]');
  const labels: Record<string, string> = { All: '전체', Backend: '백엔드', Data: '데이터', AI: 'AI' };

  filters.forEach((filter) => {
    filter.addEventListener('change', () => {
      if (!filter.checked) return;
      const domain = filter.value || 'All';
      let visible = 0;
      projects.forEach((project) => {
        const show = domain === 'All' || project.dataset.projectDomain === domain;
        project.hidden = !show;
        if (show) visible += 1;
      });
      if (status) status.textContent = `${labels[domain] ?? domain} ${visible}개 프로젝트`;
      if (empty) empty.hidden = visible > 0;
    });
  });
</script>

<style>
  .filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 34px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line-strong);
  }

  .filter-buttons {
    display: flex;
    min-width: 0;
    gap: 5px;
    margin: 0;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--surface-muted);
  }

  .filter-buttons label {
    position: relative;
    display: flex;
  }

  .filter-buttons input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0.001;
  }

  .filter-option {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 7px;
    padding: 7px 12px;
    border: 0;
    border-radius: 3px;
    background: transparent;
    color: var(--ink-soft);
    font-size: 16px;
    font-weight: 850;
    cursor: pointer;
  }

  .filter-buttons input:checked + .filter-option {
    background: var(--surface);
    color: var(--ink);
    box-shadow: 0 1px 4px rgba(23, 26, 29, 0.14);
  }

  .filter-buttons input:focus-visible + .filter-option {
    outline: 3px solid var(--focus);
    outline-offset: 3px;
  }

  .filter-option > span {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  #filter-status {
    color: var(--ink-faint);
    font-family: var(--sans);
    font-size: var(--text-label);
  }

  .archive-note-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(340px, 1fr);
    gap: 64px;
    align-items: start;
  }

  .archive-note-grid > div {
    display: grid;
    gap: 22px;
    color: var(--ink-soft);
  }

  .archive-note-grid h2 {
    font-size: var(--text-h2);
  }

  @media (max-width: 639px) {
    :global(html.no-js) .filter-bar {
      display: none;
    }

    .filter-bar {
      align-items: stretch;
      flex-direction: column;
      margin-bottom: 20px;
      padding-bottom: 0;
      border-bottom: 0;
    }

    .filter-buttons {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }

    .filter-buttons label {
      display: block;
    }

    .filter-option {
      width: 100%;
      justify-content: center;
    }

    .archive-note-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
