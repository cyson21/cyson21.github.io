---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { ArrowLeft, ArrowRight, ArrowUpRight, CircleAlert, CodeXml } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import VerificationSignal from '../../components/VerificationSignal.astro';
import DecisionGrid from '../../components/DecisionGrid.astro';
import CodeEvidence from '../../components/CodeEvidence.astro';
import ProjectVisual from '../../components/ProjectVisual.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      previous: projects[index - 1] ?? null,
      next: projects[index + 1] ?? null,
    },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
  previous: CollectionEntry<'projects'> | null;
  next: CollectionEntry<'projects'> | null;
}

const { project, previous, next } = Astro.props;
const data = project.data;
await render(project);
const layerLabel: Record<string, string> = {
  unit: '단위 테스트',
  integration: '통합 테스트',
  'container-smoke': '컨테이너 테스트',
  'static-demo': '정적 데모',
  'live-demo': '공개 데모',
  cloud: '클라우드 환경',
};
const toc = [
  ['overview', '프로젝트 개요'],
  ['decisions', '기술 선택'],
  ['evidence', '주요 구현'],
  ['verification', '테스트 결과'],
  ['scope', '프로젝트 범위'],
];
---

<BaseLayout
  title={data.seo.title}
  description={data.seo.description}
  image={data.visual.kind === 'image' ? data.visual.src : undefined}
  imageAlt={data.visual.alt}
  article={true}
  updatedAt={data.updatedAt}
>
  <header class="project-hero">
    <div class="container project-hero-grid">
      <div class="project-heading">
        <a class="back-link" href="/projects/"><ArrowLeft size={17} aria-hidden="true" /> 프로젝트 목록</a>
        <h1>{data.name}</h1>
        <p class="project-lede">{data.summary}</p>
        <p class="project-meta-compact">{data.role} · {data.period} · {data.domain}</p>
        <div class="button-row project-actions">
          {data.links.github && <a class="button" href={data.links.github} target="_blank" rel="noreferrer" aria-label={`${data.name} GitHub 저장소 새 창에서 열기`}><CodeXml size={17} aria-hidden="true" /> GitHub <ArrowUpRight size={15} aria-hidden="true" /></a>}
          {data.links.demo && <a class="button button--secondary" href={data.links.demo} target="_blank" rel="noreferrer" aria-label={`${data.name} 데모 새 창에서 열기`}>데모 <ArrowUpRight size={17} aria-hidden="true" /></a>}
          {data.publicationState === 'case-study-only' && <span class="scope-badge"><CircleAlert size={16} aria-hidden="true" /> 문서만 공개</span>}
        </div>
      </div>
      <dl class="project-meta">
        <div><dt>역할</dt><dd>{data.role}</dd></div>
        <div><dt>기간</dt><dd>{data.period}</dd></div>
        <div><dt>분야</dt><dd>{data.domain}</dd></div>
        <div><dt>코드·테스트</dt><dd>주요 코드 {data.codeEvidence.length}개 · 관련 테스트 {data.codeEvidence.length}개</dd></div>
      </dl>
    </div>
  </header>

  <div class="container project-layout">
    <aside class="project-toc no-print">
      <p id="project-toc-title">목차</p>
      <nav aria-labelledby="project-toc-title">
        {toc.map(([id, label], index) => <a href={`#${id}`} aria-current={index === 0 ? 'location' : undefined}>{label}</a>)}
      </nav>
      <div class="toc-stack">
        <p>기술 스택</p>
        <ul class="tag-list">{data.stack.map((item) => <li class="tag">{item}</li>)}</ul>
      </div>
    </aside>

    <article class="project-content">
      <section id="overview" class="project-section" tabindex="-1">
        <h2>해결한 문제와 담당 역할</h2>
        <p class="section-lede">{data.problem}</p>
        <div class="responsibility-list">
          {data.responsibilities.map((item) => <p>{item}</p>)}
        </div>
        <div class="overview-rules">
          <h3>핵심 요구사항</h3>
          <ul class="protection-list">
            {data.protectionRules.map((rule) => <li><strong>{rule}</strong></li>)}
          </ul>
        </div>
      </section>

      <div class="visual-wrap">
        <ProjectVisual name={data.name} visual={data.visual} flow={data.flow.normal} />
      </div>

      <section id="decisions" class="project-section project-section--wide" tabindex="-1">
        <h2>기술 선택과 이유</h2>
        <DecisionGrid items={data.decisions} />
      </section>

      <section id="evidence" class="project-section project-section--wide" tabindex="-1">
        <h2>주요 구현과 관련 테스트</h2>
        <p class="section-lede">핵심 로직과 동작을 확인한 테스트를 함께 정리했습니다.</p>
        <CodeEvidence items={data.codeEvidence} results={data.verification.map((item) => item.result)} />
      </section>

      <section id="verification" class="project-section project-section--wide" tabindex="-1">
        <h2>테스트 결과</h2>
        <div class="signal-detail-grid">
          {data.signals.map((signal) => <VerificationSignal {...signal} />)}
        </div>
        <details class="verification-details">
          <summary>테스트 방법 보기</summary>
          <table class="verification-table">
            <caption class="visually-hidden">{data.name} 테스트 결과</caption>
            <thead>
              <tr><th scope="col">구분</th><th scope="col">테스트 방법</th><th scope="col">결과</th></tr>
            </thead>
            <tbody>
              {data.verification.map((item) => (
                <tr>
                  <th scope="row" class="level" data-label="구분">{layerLabel[item.layer]}</th>
                  <td data-label="테스트 방법">{item.method}</td>
                  <td data-label="결과">{item.result}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      </section>

      <section id="scope" class="project-section scope-grid" tabindex="-1">
        <h2>프로젝트 범위</h2>
        <div>
          <h3>제외 범위</h3>
          <ul class="rule-list">{data.limitations.map((item) => <li>{item}</li>)}</ul>
        </div>
        <div>
          <h3>향후 개선</h3>
          <ul class="rule-list">{data.next.map((item) => <li>{item}</li>)}</ul>
        </div>
      </section>

      {(data.links.adr || data.links.design || data.links.testReport) && (
        <section class="project-resources" aria-label="프로젝트 외부 자료">
          <p>관련 자료</p>
          <div>
            {data.links.adr && <a href={data.links.adr} target="_blank" rel="noreferrer" aria-label={`${data.name} ADR 새 창에서 열기`}>ADR <ArrowUpRight size={15} aria-hidden="true" /></a>}
            {data.links.design && <a href={data.links.design} target="_blank" rel="noreferrer" aria-label={`${data.name} 설계 문서 새 창에서 열기`}>설계 문서 <ArrowUpRight size={15} aria-hidden="true" /></a>}
            {data.links.testReport && <a href={data.links.testReport} target="_blank" rel="noreferrer" aria-label={`${data.name} 테스트 소스 새 창에서 열기`}>테스트 소스 <ArrowUpRight size={15} aria-hidden="true" /></a>}
          </div>
        </section>
      )}
    </article>
  </div>

  <nav class="project-pagination" aria-label="프로젝트 이전 다음">
    <div class="container pagination-grid">
      {previous ? <a href={`/projects/${previous.id}/`}><span><ArrowLeft size={16} aria-hidden="true" /> 이전 프로젝트</span><strong>{previous.data.name}</strong></a> : <span></span>}
      {next ? <a class="next" href={`/projects/${next.id}/`}><span>다음 프로젝트 <ArrowRight size={16} aria-hidden="true" /></span><strong>{next.data.name}</strong></a> : <a class="next" href="/projects/"><span>목록으로</span><strong>전체 프로젝트</strong></a>}
    </div>
  </nav>
</BaseLayout>

<script>
  const sectionLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.project-toc a[href^="#"]'));
  const sections = sectionLinks.flatMap((link) => {
    const section = document.getElementById(link.hash.slice(1));
    return section ? [section] : [];
  });

  const setCurrent = (id: string, scrollLink = false) => {
    sectionLinks.forEach((link) => {
      const active = link.hash === `#${id}`;
      if (active) {
        link.setAttribute('aria-current', 'location');
        if (scrollLink) link.scrollIntoView({ block: 'nearest', inline: 'center' });
      } else link.removeAttribute('aria-current');
    });
  };

  const focusFragment = () => {
    const id = decodeURIComponent(window.location.hash.slice(1));
    if (!id) return;
    const target = document.getElementById(id);
    if (!target) return;
    setCurrent(id, true);
    window.requestAnimationFrame(() => target.focus({ preventScroll: true }));
  };

  window.addEventListener('hashchange', focusFragment);
  focusFragment();

  const observer = new IntersectionObserver((entries) => {
    const visible = entries
      .filter((entry) => entry.isIntersecting)
      .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
    if (visible?.target.id) setCurrent(visible.target.id, true);
  }, { rootMargin: '-18% 0px -68% 0px', threshold: [0, 0.1] });
  sections.forEach((section) => observer.observe(section));
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .project-hero {
    padding-block: 48px 64px;
    border-bottom: 1px solid var(--line-strong);
  }

  .project-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.42fr);
    gap: 64px;
    align-items: end;
  }

  .back-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 6px;
    margin-bottom: 42px;
    color: var(--ink-soft);
    font-size: 16px;
    font-weight: 800;
  }

  .project-heading h1 {
    max-width: 950px;
    font-size: var(--text-h1);
  }

  .project-lede {
    max-width: min(760px, 40ic);
    margin-top: 24px;
    color: var(--ink-soft);
    font-size: var(--text-lede);
    line-height: 1.6;
  }

  .project-actions {
    margin-top: 30px;
  }

  .project-meta-compact {
    display: none;
  }

  .scope-badge {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 7px;
    padding: 8px 12px;
    border: 1px solid var(--amber);
    border-radius: 4px;
    background: var(--amber-soft);
    color: var(--amber);
    font-size: var(--text-dense);
    font-weight: 800;
  }

  .project-meta {
    margin: 0;
    border-top: 1px solid var(--line-strong);
  }

  .project-meta div {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 14px;
    padding-block: 13px;
    border-bottom: 1px solid var(--line-strong);
  }

  .project-meta dt {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .project-meta dd {
    margin: 0;
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .project-layout {
    display: grid;
    grid-template-columns: 200px minmax(0, 1fr);
    gap: 64px;
    align-items: start;
    padding-block: 64px;
  }

  .project-toc {
    position: sticky;
    top: calc(var(--header-height) + 28px);
    grid-row: 1 / span 2;
  }

  .project-toc > p,
  .toc-stack > p {
    margin-bottom: 12px;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .project-toc nav {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .project-toc nav a {
    display: block;
    padding-block: 9px;
    border-bottom: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 16px;
    font-weight: 750;
    text-decoration: none;
  }

  .project-toc nav a[aria-current='location'] {
    color: var(--blue);
    font-weight: 850;
  }

  .toc-stack {
    margin-top: 34px;
  }

  .project-content {
    grid-column: 2;
    min-width: 0;
  }

  .visual-wrap {
    min-width: 0;
    margin-bottom: 64px;
  }

  .project-section {
    width: min(100%, var(--reading));
    padding-block: 0 64px;
    scroll-margin-top: calc(var(--header-height) + 25px);
  }

  .project-section + .project-section {
    padding-top: 6px;
  }

  .project-section--wide {
    width: 100%;
  }

  .project-section h2 {
    margin-bottom: 20px;
    font-size: var(--text-h2);
  }

  .section-lede {
    max-width: min(760px, 40ic);
    margin-bottom: 24px;
    color: var(--ink-soft);
    font-size: var(--text-lede);
    line-height: 1.6;
  }

  .responsibility-list {
    display: grid;
    border-top: 1px solid var(--line-strong);
  }

  .responsibility-list > div {
    padding-block: 16px;
    border-bottom: 1px solid var(--line-strong);
  }

  .responsibility-list > p {
    position: relative;
    padding: 16px 0 16px 24px;
    border-bottom: 1px solid var(--line-strong);
  }

  .responsibility-list > p::before {
    position: absolute;
    top: 1.85em;
    left: 2px;
    width: 8px;
    height: 2px;
    background: var(--blue);
    content: "";
  }

  .overview-rules {
    margin-top: 40px;
  }

  .overview-rules h3 {
    margin-bottom: 16px;
  }

  .signal-detail-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  .protection-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--ink);
    list-style: none;
  }

  .protection-list li {
    position: relative;
    padding: 16px 0 16px 24px;
    border-bottom: 1px solid var(--line-strong);
  }

  .protection-list li::before {
    position: absolute;
    top: 1.85em;
    left: 2px;
    width: 8px;
    height: 2px;
    background: var(--blue);
    content: "";
  }

  .protection-list strong {
    font-size: var(--text-body);
  }

  .verification-table {
    width: 100%;
    border-collapse: collapse;
    border-top: 1px solid var(--line-strong);
    border-left: 1px solid var(--line-strong);
  }

  .verification-details {
    border-top: 1px solid var(--line-strong);
  }

  .verification-details summary {
    min-height: 44px;
    padding-block: 12px;
    color: var(--blue);
    font-size: 16px;
    font-weight: 800;
    cursor: pointer;
  }

  .verification-table th,
  .verification-table td {
    padding: 14px;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    text-align: left;
    vertical-align: top;
  }

  .verification-table thead {
    background: var(--ink);
    color: white;
  }

  .verification-table thead th {
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .verification-table tbody tr {
    background: var(--surface);
  }

  .verification-table td {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .verification-table .level {
    width: 150px;
    color: var(--green);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .verification-table [data-label]::before {
    display: none;
  }

  .scope-grid {
    display: grid;
    width: 100%;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .scope-grid > h2 {
    grid-column: 1 / -1;
    margin-bottom: -8px;
  }

  .scope-grid > div {
    padding: 24px;
    border-top: 4px solid var(--amber);
    background: var(--amber-soft);
  }

  .scope-grid > div:last-child {
    border-top-color: var(--blue);
    background: var(--blue-soft);
  }

  .scope-grid h3 {
    margin-bottom: 16px;
    font-size: var(--text-h3);
  }

  .scope-grid .rule-list {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .project-resources {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 20px;
    border: 1px solid var(--line-strong);
    background: var(--surface);
  }

  .project-resources > p {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .project-resources > div {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  .project-resources a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 5px;
    font-size: 16px;
    font-weight: 800;
  }

  .project-pagination {
    border-top: 1px solid var(--line-strong);
    background: var(--surface);
  }

  .pagination-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .pagination-grid > a {
    display: grid;
    gap: 7px;
    min-height: 130px;
    align-content: center;
    padding: 28px 0;
    text-decoration: none;
  }

  .pagination-grid > a:first-child {
    padding-right: 28px;
    border-right: 1px solid var(--line-strong);
  }

  .pagination-grid .next {
    padding-left: 28px;
    text-align: right;
  }

  .pagination-grid a span {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .pagination-grid .next span {
    justify-content: flex-end;
  }

  @media (max-width: 959px) {
    .project-hero-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 40px;
    }

    .project-heading {
      min-width: 0;
    }

    .project-meta {
      max-width: 640px;
    }

    .project-layout {
      grid-template-columns: minmax(0, 1fr);
      gap: 0;
      padding-top: 0;
    }

    .project-toc {
      position: static;
      display: block;
      margin-bottom: 40px;
      padding-block: 20px;
      border-top: 1px solid var(--line-strong);
      border-bottom: 1px solid var(--line-strong);
      background: var(--paper);
    }

    .project-toc,
    .project-toc nav {
      min-width: 0;
      max-width: 100%;
    }

    .project-toc > p {
      margin-bottom: 7px;
    }

    .project-toc nav {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 20px;
      border: 0;
    }

    .project-toc nav a {
      display: inline-flex;
      flex: 0 0 auto;
      align-items: center;
      gap: 6px;
      min-height: 44px;
      padding: 4px 0;
      border: 0;
      background: transparent;
      line-height: 1.35;
    }

    .project-toc nav a[aria-current='location'] {
      color: var(--blue);
      text-decoration: underline;
    }

    .toc-stack {
      display: none;
    }

    .project-section {
      scroll-margin-top: calc(var(--header-height) + 24px);
    }

    .project-content {
      grid-column: 1;
    }

    .visual-wrap {
      margin-bottom: 56px;
    }
  }

  @media (max-width: 639px) {
    .project-hero {
      padding-block: 24px 32px;
    }

    .project-hero-grid {
      gap: 20px;
    }

    .back-link {
      margin-bottom: 12px;
    }

    .project-heading h1 {
      overflow-wrap: anywhere;
    }

    .project-lede {
      margin-top: 16px;
      line-height: 1.6;
    }

    .project-actions {
      margin-top: 20px;
    }

    .project-meta-compact {
      display: block;
      margin-top: 12px;
      color: var(--ink-faint);
      font-family: var(--mono);
      font-size: var(--text-dense);
      font-weight: 700;
      line-height: 1.5;
    }

    .project-meta {
      display: none;
    }

    .visual-wrap {
      margin-bottom: 42px;
    }

    .signal-detail-grid,
    .scope-grid {
      grid-template-columns: 1fr;
    }

    .verification-table {
      display: block;
      border-left: 0;
    }

    .verification-table thead {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      clip-path: inset(50%);
    }

    .verification-table tbody {
      display: grid;
      gap: 14px;
    }

    .verification-table tbody tr {
      display: grid;
      grid-template-columns: 1fr;
      border: 1px solid var(--line-strong);
    }

    .verification-table th,
    .verification-table td {
      display: grid;
      width: 100%;
      grid-template-columns: 68px minmax(0, 1fr);
      gap: 12px;
      border-right: 0;
    }

    .verification-table [data-label]::before {
      display: block;
      color: var(--ink-faint);
      content: attr(data-label);
      font-family: var(--mono);
      font-size: var(--text-label);
      font-weight: 800;
    }

    .project-resources {
      align-items: flex-start;
