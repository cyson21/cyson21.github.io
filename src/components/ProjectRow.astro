---
import { ArrowRight, ArrowUpRight } from '@lucide/astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  headingLevel?: 2 | 3;
  compact?: boolean;
}

const { project, headingLevel = 3, compact = false } = Astro.props;
const data = project.data;
const primarySignal = data.signals[0];
---

<article class:list={['project-row', { 'project-row--compact': compact }]}>
  <div class="project-main">
    <div class="project-copy">
      <div class="project-title-line">
        <div>
          {headingLevel === 2
            ? <h2><a href={`/projects/${project.id}/`}>{data.name}</a></h2>
            : <h3><a href={`/projects/${project.id}/`}>{data.name}</a></h3>}
        </div>
        <div class="project-status">
          <span class="domain">{data.domain}</span>
          {data.publicationState === 'case-study-only' && <span class="case-study">문서만 공개</span>}
        </div>
      </div>
      <p class="project-summary">{data.summary}</p>
      <div class="project-footnote">
        <ul class="tag-list" aria-label={`${data.name} 기술`}>
          {data.stack.slice(0, 5).map((item) => <li class="tag">{item}</li>)}
        </ul>
        <span class="project-period">{data.period}</span>
      </div>
    </div>
  </div>
  {primarySignal && !compact && <div class="project-proof">
    <p class="proof-label">{primarySignal.label}</p>
    <strong>{primarySignal.expression}</strong>
    <span>{primarySignal.result}</span>
    <div class="project-links">
      <a href={`/projects/${project.id}/`} aria-label={`${data.name} 프로젝트 상세 보기`}>자세히 보기 <ArrowRight size={16} aria-hidden="true" /></a>
      {data.links.github && <a href={data.links.github} target="_blank" rel="noreferrer" aria-label={`${data.name} GitHub 저장소 새 창에서 열기`}>GitHub <ArrowUpRight size={15} aria-hidden="true" /></a>}
    </div>
  </div>}
</article>

<style>
  .project-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.34fr);
    gap: 24px;
    padding-block: 34px;
    border-top: 1px solid var(--line);
  }

  .project-row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .project-main,
  .project-copy,
  .project-proof {
    min-width: 0;
  }

  .project-copy {
    display: grid;
    gap: 14px;
  }

  .project-title-line {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 20px;
  }

  .project-title-line h2 {
    font-size: var(--text-h2);
  }

  .project-title-line h3 {
    font-size: var(--text-h3);
  }

  .project-title-line :is(h2, h3) a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    text-decoration: none;
  }

  .project-status {
    display: flex;
    flex: 0 0 auto;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
  }

  .domain,
  .case-study {
    padding: 3px 7px;
    border: 1px solid var(--line-strong);
    border-radius: 3px;
    color: var(--ink-soft);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .case-study {
    border-color: var(--amber);
    background: var(--amber-soft);
    color: var(--amber);
  }

  .project-summary {
    max-width: 760px;
    color: var(--ink-soft);
  }

  .project-footnote {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
  }

  .project-period {
    flex: 0 0 auto;
    color: var(--ink-faint);
    font-family: var(--sans);
    font-size: var(--text-code);
    font-variant-numeric: tabular-nums;
  }

  .project-proof {
    display: grid;
    align-content: start;
    gap: 7px;
    padding: 18px;
    border-left: 3px solid var(--green);
    background: var(--green-soft);
  }

  .proof-label {
    color: var(--green);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .project-proof strong {
    overflow-wrap: anywhere;
    font-family: var(--mono);
    font-size: var(--text-dense);
    line-height: 1.45;
  }

  .project-proof > span {
    color: var(--ink-soft);
    font-size: var(--text-dense);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 5px;
  }

  .project-links a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 4px;
    padding-inline: 4px;
    color: var(--ink);
    font-size: 16px;
    font-weight: 800;
  }

  .project-row--compact {
    display: block;
    padding-block: 32px;
  }

  .project-row--compact .tag-list {
    display: none;
  }

  @media (max-width: 959px) {
    .project-row {
      grid-template-columns: 1fr;
    }

    .project-proof {
      grid-column: 1;
    }
  }

  @media (max-width: 639px) {
    .project-row {
      grid-template-columns: 1fr;
      gap: 16px;
      padding-block: 24px;
    }

    .project-title-line {
      flex-direction: column;
      gap: 8px;
    }

    .project-status {
      justify-content: flex-start;
    }

    .project-footnote {
      align-items: start;
      flex-direction: column;
      gap: 8px;
    }

    .project-proof {
      gap: 4px;
      padding: 12px 14px;
    }

    .project-row--compact .project-footnote {
      margin-top: 2px;
    }
  }
</style>
