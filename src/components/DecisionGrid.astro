---
interface Decision {
  title: string;
  choice: string;
  alternative: string;
  reason: string;
}

interface Props {
  items: Decision[];
}

const { items } = Astro.props;
---

<div class="decision-grid" data-count={items.length}>
  {items.map((item) => (
    <article class="decision-item">
      <h3>{item.title}</h3>
      <dl>
        <div><dt>적용 방식</dt><dd>{item.choice}</dd></div>
        <div><dt>검토한 대안</dt><dd>{item.alternative}</dd></div>
        <div><dt>선택 이유</dt><dd>{item.reason}</dd></div>
      </dl>
    </article>
  ))}
</div>

<style>
  .decision-grid {
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--line-strong);
    border-left: 1px solid var(--line-strong);
  }

  .decision-item {
    min-width: 0;
    padding: 24px;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    background: var(--surface);
  }

  .decision-item h3 {
    font-size: var(--text-h3);
  }

  .decision-item dl {
    display: grid;
    gap: 13px;
    margin: 22px 0 0;
  }

  .decision-item dl div {
    display: grid;
    grid-template-columns: 90px minmax(0, 1fr);
    gap: 10px;
  }

  .decision-item dt {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .decision-item dd {
    min-width: 0;
    margin: 0;
    color: var(--ink-soft);
    font-size: var(--text-dense);
    overflow-wrap: anywhere;
  }

  @media (min-width: 960px) {
    .decision-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .decision-grid[data-count='3'] .decision-item:last-child {
      grid-column: 1 / -1;
    }
  }
</style>
