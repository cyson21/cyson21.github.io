---
interface Decision {
  title: string;
  choice: string;
  alternative: string;
  reason: string;
}

interface Props {
  items: Decision[];
}

const { items } = Astro.props;
---

<div class="decision-grid">
  {items.map((item, index) => (
    <article class="decision-item">
      <span class="decision-index">D{String(index + 1).padStart(2, '0')}</span>
      <h3>{item.title}</h3>
      <dl>
        <div><dt>선택</dt><dd>{item.choice}</dd></div>
        <div><dt>대안</dt><dd>{item.alternative}</dd></div>
        <div><dt>판단</dt><dd>{item.reason}</dd></div>
      </dl>
    </article>
  ))}
</div>

<style>
  .decision-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--line-strong);
    border-left: 1px solid var(--line-strong);
  }

  .decision-item {
    min-width: 0;
    padding: 24px;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    background: var(--surface);
  }

  .decision-index {
    color: var(--blue);
    font-family: var(--mono);
    font-size: 0.67rem;
    font-weight: 800;
  }

  .decision-item h3 {
    margin-top: 8px;
    font-size: 1.12rem;
  }

  .decision-item dl {
    display: grid;
    gap: 13px;
    margin: 22px 0 0;
  }

  .decision-item dl div {
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr);
    gap: 10px;
  }

  .decision-item dt {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.69rem;
    font-weight: 800;
  }

  .decision-item dd {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.87rem;
  }

  @media (max-width: 720px) {
    .decision-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
