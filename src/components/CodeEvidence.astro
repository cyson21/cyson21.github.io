---
import { ArrowUpRight } from '@lucide/astro';

interface Evidence {
  symbol: string;
  displayPath: string;
  sourceUrl?: string | undefined;
  excerpt: string;
  proves: string;
  testName: string;
  testPath: string;
  testUrl?: string | undefined;
}

interface Props {
  items: Evidence[];
}

const { items } = Astro.props;
---

<div class="evidence-list">
  {items.map((item, index) => (
    <article class="evidence">
      <header class="evidence-header">
        <div>
          <p class="evidence-count">코드 근거 {String(index + 1).padStart(2, '0')}</p>
          <h3><code>{item.symbol}</code></h3>
        </div>
        {item.sourceUrl
          ? <a class="evidence-path" href={item.sourceUrl} target="_blank" rel="noreferrer" aria-label={`${item.symbol} 구현 파일 새 창에서 열기`}><code>{item.displayPath}</code><ArrowUpRight size={14} aria-hidden="true" /></a>
          : <p class="evidence-path"><code>{item.displayPath}</code></p>}
      </header>
      <div class="evidence-body">
        <div class="code-panel">
          <p class="panel-label">구현</p>
          <pre tabindex="0" aria-label={`${item.symbol} 코드 발췌`}><code>{item.excerpt}</code></pre>
        </div>
        <div class="evidence-context">
          <section aria-labelledby={`rule-${index}`}>
            <h4 id={`rule-${index}`}>보호하는 규칙</h4>
            <p>{item.proves}</p>
          </section>
          <section aria-labelledby={`test-${index}`}>
            <h4 id={`test-${index}`}>연결 테스트</h4>
            <code class="test-name">{item.testName}</code>
            {item.testUrl
              ? <a class="test-path" href={item.testUrl} target="_blank" rel="noreferrer" aria-label={`${item.testName} 테스트 새 창에서 열기`}><code>{item.testPath}</code><ArrowUpRight size={14} aria-hidden="true" /></a>
              : <code class="test-path">{item.testPath}</code>}
          </section>
        </div>
      </div>
    </article>
  ))}
</div>

<style>
  .evidence-list {
    display: grid;
    gap: 28px;
  }

  .evidence {
    overflow: hidden;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .evidence-header {
    display: grid;
    grid-template-columns: minmax(0, 0.65fr) minmax(280px, 1fr);
    gap: 24px;
    align-items: end;
    padding: 20px;
    border-bottom: 1px solid #46504b;
  }

  .evidence-count,
  .panel-label {
    margin-bottom: 5px;
    color: var(--blue);
    font-family: var(--mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .evidence-header h3 code {
    overflow-wrap: anywhere;
    font-family: var(--mono);
    font-size: 1rem;
  }

  .evidence-path,
  .test-path {
    display: inline-flex;
    min-width: 0;
    min-height: 44px;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.82rem;
    line-height: 1.5;
    text-align: right;
  }

  .evidence-path code,
  .test-path code,
  code.test-path {
    overflow-wrap: anywhere;
    font: inherit;
  }

  .evidence-body {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    background: #101417;
    color: #f5f8f6;
  }

  .code-panel,
  .evidence-context {
    min-width: 0;
    padding: 20px;
  }

  .code-panel {
    border-right: 1px solid #46504b;
  }

  .code-panel .panel-label {
    margin-bottom: 14px;
    color: #8ab9ff;
  }

  pre {
    max-width: 100%;
    margin: 0;
    overflow-x: auto;
    border-radius: 3px;
    color: #e5eee9;
    font-family: var(--mono);
    font-size: 0.84rem;
    line-height: 1.68;
    white-space: pre;
  }

  pre:focus-visible {
    outline: 3px solid #ffcf70;
    outline-offset: 5px;
    background: #1c2420;
  }

  .evidence-context {
    display: grid;
    gap: 0;
    align-content: start;
  }

  .evidence-context section {
    display: grid;
    gap: 10px;
    padding-block: 4px 20px;
  }

  .evidence-context section + section {
    padding-block: 20px 4px;
    border-top: 1px solid #46504b;
  }

  .evidence-context h4 {
    color: #72e0b6;
    font-family: var(--mono);
    font-size: 0.82rem;
  }

  .evidence-context p {
    color: #e5eae7;
    font-size: 0.95rem;
  }

  .test-name {
    overflow-wrap: anywhere;
    color: #ffffff;
    font-family: var(--mono);
    font-size: 0.84rem;
  }

  .evidence-context .test-path {
    justify-content: flex-start;
    color: #bfc9c4;
    text-align: left;
  }

  .evidence-context a:hover {
    color: #a9cbff;
  }

  @media (max-width: 760px) {
    .evidence-header,
    .evidence-body {
      grid-template-columns: 1fr;
    }

    .evidence-header {
      gap: 8px;
      padding: 16px;
    }

    .evidence-path {
      justify-content: flex-start;
      text-align: left;
    }

    .code-panel {
      border-right: 0;
      border-bottom: 1px solid #46504b;
    }

    .code-panel,
    .evidence-context {
      padding: 16px;
    }
  }
</style>
