---
import { ArrowUpRight } from '@lucide/astro';

interface Evidence {
  symbol: string;
  displayPath: string;
  sourceUrl?: string | undefined;
  excerpt: string;
  proves: string;
  testName: string;
  testPath: string;
  testUrl?: string | undefined;
}

interface Props {
  items: Evidence[];
  results?: string[];
}

const { items, results = [] } = Astro.props;
---

<div class="evidence-list">
  {items.map((item, index) => (
    <details class="evidence" open={index === 0}>
      <summary class="evidence-header">
        <div>
          <p class="evidence-count">{index === 0 ? '주요 구현' : '추가 구현'}</p>
          <h3><code>{item.symbol}</code></h3>
        </div>
        <p class="evidence-path"><code>{item.displayPath}</code></p>
      </summary>
      <div class="evidence-body">
        <div class="code-panel">
          <div class="code-panel-header">
            <p class="panel-label">코드</p>
            {item.sourceUrl && (
              <a class="source-link" href={item.sourceUrl} target="_blank" rel="noreferrer" aria-label={`${item.symbol} 구현 파일 새 창에서 열기`}>
                소스 파일 열기 <ArrowUpRight size={15} aria-hidden="true" />
              </a>
            )}
          </div>
          <pre tabindex="0" aria-label={`${item.symbol} 코드 발췌`}><code>{item.excerpt}</code></pre>
        </div>
        <div class="evidence-context">
          <section aria-labelledby={`rule-${index}`}>
            <h4 id={`rule-${index}`}>구현 내용</h4>
            <p>{item.proves}</p>
          </section>
          <section aria-labelledby={`test-${index}`}>
            <h4 id={`test-${index}`}>관련 테스트</h4>
            <code class="test-name">{item.testName}</code>
            {item.testUrl
              ? <a class="test-path" href={item.testUrl} target="_blank" rel="noreferrer" aria-label={`${item.testName} 테스트 새 창에서 열기`}><code>{item.testPath}</code><ArrowUpRight size={14} aria-hidden="true" /></a>
              : <code class="test-path">{item.testPath}</code>}
            {results[index] && <p class="test-result"><strong>테스트 결과</strong><span>{results[index]}</span></p>}
          </section>
        </div>
      </div>
    </details>
  ))}
</div>

<style>
  .evidence-list {
    display: grid;
    gap: 28px;
  }

  .evidence {
    overflow: hidden;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .evidence > summary {
    cursor: pointer;
    list-style: none;
  }

  .evidence > summary::-webkit-details-marker {
    display: none;
  }

  .evidence:not([open]) .evidence-header {
    border-bottom: 0;
  }

  .evidence:not([open]) .evidence-header::after {
    content: "열기 +";
  }

  .evidence-header::after {
    align-self: center;
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    color: var(--blue);
    content: "접기 −";
    font-size: 16px;
    font-weight: 800;
  }

  .evidence-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px 24px;
    align-items: start;
    padding: 20px;
    border-bottom: 1px solid #46504b;
  }

  .evidence-header > div {
    grid-column: 1;
    grid-row: 1;
  }

  .evidence-count,
  .panel-label {
    margin-bottom: 5px;
    color: var(--blue);
    font-family: var(--sans);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .evidence-header h3 code {
    overflow-wrap: anywhere;
    font-family: var(--mono);
    font-size: var(--text-dense);
  }

  .evidence-path {
    display: block;
    grid-column: 1 / -1;
    grid-row: 2;
    min-width: 0;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-code);
    line-height: 1.55;
    text-align: left;
  }

  .test-path {
    display: inline-flex;
    min-width: 0;
    min-height: 44px;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: var(--text-code);
    line-height: 1.55;
    text-align: right;
  }

  .evidence-path code,
  .test-path code,
  code.test-path {
    overflow-wrap: anywhere;
    font: inherit;
  }

  .evidence-body {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    background: #101417;
    color: #f5f8f6;
  }

  .code-panel,
  .evidence-context {
    min-width: 0;
    padding: 20px;
  }

  .code-panel {
    border-right: 1px solid #46504b;
  }

  .code-panel-header {
    display: flex;
    min-height: 44px;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
  }

  .code-panel .panel-label {
    margin-bottom: 0;
    color: #8ab9ff;
  }

  .source-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 6px;
    color: #d8e7ff;
    font-size: var(--text-dense);
    font-weight: 800;
  }

  .source-link:hover {
    color: #ffffff;
  }

  pre {
    max-width: 100%;
    margin: 0;
    overflow-x: auto;
    border-radius: 3px;
    color: #e5eee9;
    font-family: var(--mono);
    font-size: var(--text-code);
    line-height: 1.55;
    white-space: pre;
  }

  pre:focus-visible {
    outline: 3px solid #ffcf70;
    outline-offset: 5px;
    background: #1c2420;
  }

  .evidence-context {
    display: grid;
    gap: 0;
    align-content: start;
  }

  .evidence-context section {
    display: grid;
    gap: 10px;
    padding-block: 4px 20px;
  }

  .evidence-context section + section {
    padding-block: 20px 4px;
    border-top: 1px solid #46504b;
  }

  .evidence-context h4 {
    color: #72e0b6;
    font-family: var(--sans);
    font-size: var(--text-label);
  }

  .evidence-context p {
    color: #e5eae7;
    font-size: var(--text-dense);
  }

  .test-name {
    overflow-wrap: anywhere;
    color: #ffffff;
    font-family: var(--mono);
    font-size: var(--text-code);
    line-height: 1.55;
  }

  .test-result {
    display: grid;
    gap: 4px;
    padding-top: 12px;
    border-top: 1px solid #46504b;
    color: #e5eae7;
    font-size: var(--text-dense);
  }

  .test-result strong {
    color: #72e0b6;
    font-size: var(--text-label);
  }

  .evidence-context .test-path {
    justify-content: flex-start;
    color: #bfc9c4;
    text-align: left;
  }

  .evidence-context a:hover {
    color: #a9cbff;
  }

  @media (max-width: 959px) {
    .evidence-header,
    .evidence-body {
      grid-template-columns: 1fr;
    }

    .evidence-header {
      gap: 8px;
      padding: 16px;
    }

    .evidence-path {
      justify-content: flex-start;
      text-align: left;
    }

    .code-panel {
      border-right: 0;
      border-bottom: 1px solid #46504b;
    }

    .code-panel,
    .evidence-context {
      padding: 16px;
    }

    .code-panel-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
    }
  }
</style>
