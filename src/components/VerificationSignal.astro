---
import { ArrowUpRight } from '@lucide/astro';

interface Props {
  label: string;
  expression: string;
  result: string;
  source?: string;
  sourceUrl?: string | undefined;
  tone?: 'success' | 'warning' | 'danger';
  compact?: boolean;
}

const { label, expression, result, source, sourceUrl, tone = 'success', compact = false } = Astro.props;
const sourceParts = source?.split('::') ?? [];
const sourceFile = sourceParts[0] ?? '';
const sourceTest = sourceParts.slice(1).join('::');
const sourceFileSegments = sourceFile.match(/[^_]+_?/g) ?? [];
const sourceTestSegments = sourceTest.match(/[^_]+_?/g) ?? [];
---

<article class:list={['signal', `signal--${tone}`, { 'signal--compact': compact }]}> 
  <div class="signal-topline">
    <span class="signal-dot" aria-hidden="true"></span>
    <span class="signal-label">{label}</span>
  </div>
  <p class="signal-expression">{expression}</p>
  <p class="signal-result">{result}</p>
  {source && (
    sourceUrl
      ? (
        <a
          class="signal-source"
          href={sourceUrl}
          target="_blank"
          rel="noreferrer"
          aria-label={`${label} 검증 근거 새 창에서 열기`}
          title={source}
        >
          <span class="signal-source-label">근거</span>
          <code>
            <span class="source-file">
              {sourceFileSegments.map((segment) => <>{segment}<wbr /></>)}
            </span>
            {sourceTest && (
              <span class="source-test">
                {sourceTestSegments.map((segment) => <>{segment}<wbr /></>)}
              </span>
            )}
          </code>
          <ArrowUpRight class="source-icon" size={14} aria-hidden="true" />
        </a>
      )
      : (
        <p class="signal-source" title={source}>
          <span class="signal-source-label">근거</span>
          <code>
            <span class="source-file">
              {sourceFileSegments.map((segment) => <>{segment}<wbr /></>)}
            </span>
            {sourceTest && (
              <span class="source-test">
                {sourceTestSegments.map((segment) => <>{segment}<wbr /></>)}
              </span>
            )}
          </code>
        </p>
      )
  )}
</article>

<style>
  .signal {
    display: grid;
    min-height: 184px;
    align-content: start;
    gap: 9px;
    padding: 20px;
    border: 1px solid var(--line);
    border-top: 4px solid var(--green);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .signal--warning {
    border-top-color: var(--amber);
  }

  .signal--danger {
    border-top-color: var(--red);
  }

  .signal--compact {
    min-height: 0;
    padding: 16px;
  }

  .signal-topline {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .signal-dot {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--green);
  }

  .signal--warning .signal-dot {
    background: var(--amber);
  }

  .signal--danger .signal-dot {
    background: var(--red);
  }

  .signal-label {
    color: var(--ink-soft);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .signal-expression {
    font-family: var(--mono);
    font-size: var(--text-dense);
    font-weight: 800;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .signal-result {
    color: var(--green);
    font-size: var(--text-dense);
    font-weight: 800;
  }

  .signal--warning .signal-result {
    color: var(--amber);
  }

  .signal--danger .signal-result {
    color: var(--red);
  }

  .signal-source {
    position: relative;
    display: block;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid var(--line);
    color: var(--ink-faint);
    font-size: var(--text-code);
    line-height: 1.4;
    text-decoration: none;
  }

  .signal-source-label {
    display: block;
    margin-bottom: 4px;
    color: var(--ink-soft);
    font-size: var(--text-label);
    font-weight: 800;
  }

  .signal-source code {
    display: grid;
    min-width: 0;
    gap: 2px;
    font-family: var(--mono);
    font-size: var(--text-code);
    line-height: 1.55;
  }

  .source-file,
  .source-test {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .source-file {
    color: var(--ink-soft);
    font-weight: 700;
  }

  .source-test {
    display: block;
  }

  .source-icon {
    position: absolute;
    top: 12px;
    right: 0;
  }

  @media (max-width: 639px) {
    .signal {
      min-height: 0;
      padding: 18px;
    }

    .signal-expression {
      font-size: var(--text-dense);
    }
  }
</style>
