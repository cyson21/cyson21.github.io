---
import { ArrowUpRight } from '@lucide/astro';

interface Props {
  label: string;
  expression: string;
  result: string;
  source?: string;
  sourceUrl?: string | undefined;
  tone?: 'success' | 'warning' | 'danger';
  compact?: boolean;
}

const { label, expression, result, source, sourceUrl, tone = 'success', compact = false } = Astro.props;
---

<article class:list={['signal', `signal--${tone}`, { 'signal--compact': compact }]}> 
  <div class="signal-topline">
    <span class="signal-dot" aria-hidden="true"></span>
    <span class="signal-label">{label}</span>
  </div>
  <p class="signal-expression">{expression}</p>
  <p class="signal-result">{result}</p>
  {source && (
    sourceUrl
      ? <a class="signal-source" href={sourceUrl} target="_blank" rel="noreferrer" aria-label={`${label} 검증 근거 새 창에서 열기`}>근거: <code>{source}</code><ArrowUpRight size={14} aria-hidden="true" /></a>
      : <p class="signal-source">근거: <code>{source}</code></p>
  )}
</article>

<style>
  .signal {
    display: grid;
    min-height: 184px;
    align-content: start;
    gap: 10px;
    padding: 22px;
    border: 1px solid var(--line);
    border-top: 4px solid var(--green);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .signal--warning {
    border-top-color: var(--amber);
  }

  .signal--danger {
    border-top-color: var(--red);
  }

  .signal--compact {
    min-height: 0;
    padding: 16px;
  }

  .signal-topline {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .signal-dot {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--green);
  }

  .signal--warning .signal-dot {
    background: var(--amber);
  }

  .signal--danger .signal-dot {
    background: var(--red);
  }

  .signal-label {
    color: var(--ink-soft);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .signal-expression {
    font-family: var(--mono);
    font-size: 1.3rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .signal-result {
    color: var(--green);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .signal--warning .signal-result {
    color: var(--amber);
  }

  .signal--danger .signal-result {
    color: var(--red);
  }

  .signal-source {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 5px;
    margin-top: auto;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.82rem;
    line-height: 1.5;
    overflow-wrap: anywhere;
  }

  .signal-source code {
    font: inherit;
  }

  @media (max-width: 620px) {
    .signal {
      min-height: 0;
      padding: 18px;
    }

    .signal-expression {
      font-size: 1.22rem;
    }
  }
</style>
