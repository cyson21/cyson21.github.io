---
import { ArrowUpRight, Menu, X } from '@lucide/astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const links = [
  { href: '/projects/', label: '프로젝트' },
  { href: '/experience/', label: '경력' },
  { href: '/resume/', label: '이력서' },
];
const isActive = (href: string) => currentPath === href || (href !== '/' && currentPath.startsWith(href));
---

<header class="site-header">
  <div class="header-inner container">
    <a class="wordmark" href="/" aria-label="손찬양 포트폴리오 홈">
      <span class="wordmark-name">손찬양</span>
      <span class="wordmark-role">백엔드 개발자</span>
    </a>

    <nav class="desktop-nav" aria-label="주요 탐색">
      {links.map((link) => (
        <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a>
      ))}
      <a
        class="github-link"
        href="https://github.com/cyson21"
        target="_blank"
        rel="noreferrer"
        aria-label="손찬양 GitHub 프로필 새 창에서 열기"
      >
        GitHub <ArrowUpRight size={15} aria-hidden="true" />
      </a>
    </nav>

    <button class="menu-button" type="button" aria-label="탐색 메뉴 열기" aria-expanded="false" aria-controls="mobile-nav" title="메뉴">
      <Menu class="menu-open-icon" size={23} aria-hidden="true" />
      <X class="menu-close-icon" size={23} aria-hidden="true" />
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="모바일 탐색">
    <div class="container mobile-nav-inner">
      {links.map((link) => (
        <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a>
      ))}
      <a
        href="https://github.com/cyson21"
        target="_blank"
        rel="noreferrer"
        aria-label="손찬양 GitHub 프로필 새 창에서 열기"
      >GitHub <ArrowUpRight size={18} aria-hidden="true" /></a>
    </div>
  </nav>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>('.menu-button');
  const nav = document.querySelector<HTMLElement>('#mobile-nav');
  if (nav) nav.hidden = true;

  const closeMenu = (restoreFocus = false) => {
    if (!button || !nav) return;
    button.setAttribute('aria-expanded', 'false');
    button.setAttribute('aria-label', '탐색 메뉴 열기');
    nav.hidden = true;
    document.body.classList.remove('menu-open');
    if (restoreFocus) button.focus();
  };

  button?.addEventListener('click', () => {
    if (!nav) return;
    const open = button.getAttribute('aria-expanded') !== 'true';
    button.setAttribute('aria-expanded', String(open));
    button.setAttribute('aria-label', open ? '탐색 메뉴 닫기' : '탐색 메뉴 열기');
    nav.hidden = !open;
    document.body.classList.toggle('menu-open', open);
  });

  nav?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => closeMenu()));
  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape' || button?.getAttribute('aria-expanded') !== 'true') return;
    event.preventDefault();
    closeMenu(true);
  });
  window.addEventListener('resize', () => {
    if (window.innerWidth > 639) closeMenu();
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    min-height: var(--header-height);
    border-bottom: 1px solid rgba(157, 167, 162, 0.72);
    background: rgba(247, 248, 246, 0.94);
    backdrop-filter: blur(14px);
  }

  .header-inner {
    display: flex;
    min-height: var(--header-height);
    align-items: center;
    justify-content: space-between;
    gap: 28px;
  }

  .wordmark {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 12px;
    font-weight: 800;
    text-decoration: none;
  }

  .wordmark:hover {
    color: var(--ink);
  }

  .wordmark::before {
    width: 4px;
    height: 28px;
    background: var(--blue);
    content: "";
  }

  .wordmark-name {
    font-size: 1rem;
  }

  .wordmark-role {
    padding-left: 12px;
    border-left: 1px solid var(--line);
    color: var(--ink-faint);
    font-family: var(--sans);
    font-size: var(--text-label);
    font-weight: 650;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .desktop-nav a {
    position: relative;
    color: var(--ink-soft);
    font-size: 16px;
    font-weight: 720;
    line-height: 1.35;
    text-decoration: none;
  }

  .desktop-nav a:hover,
  .desktop-nav a[aria-current='page'] {
    color: var(--ink);
  }

  .desktop-nav a[aria-current='page']::after {
    position: absolute;
    right: 0;
    bottom: -23px;
    left: 0;
    height: 3px;
    background: var(--blue);
    content: "";
  }

  .desktop-nav .github-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .menu-button {
    display: none;
    width: 44px;
    height: 44px;
    place-items: center;
    padding: 0;
    border: 1px solid var(--line-strong);
    border-radius: 4px;
    background: var(--surface);
    color: var(--ink);
  }

  .menu-close-icon {
    display: none;
  }

  .menu-button[aria-expanded='true'] .menu-open-icon {
    display: none;
  }

  .menu-button[aria-expanded='true'] .menu-close-icon {
    display: block;
  }

  .mobile-nav {
    display: none;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line-strong);
    background: var(--surface);
  }

  .mobile-nav-inner {
    display: grid;
    padding-block: 10px 16px;
  }

  .mobile-nav a {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
    font-weight: 800;
    line-height: 1.35;
    text-decoration: none;
  }

  .mobile-nav a:last-child {
    border-bottom: 0;
  }

  @media (max-width: 639px) {
    .wordmark-role {
      display: none;
    }

    .desktop-nav {
      display: none;
    }

    :global(html.js) .menu-button {
      display: grid;
    }

    :global(html.js) .mobile-nav:not([hidden]) {
      display: block;
    }

    :global(html.no-js) .mobile-nav {
      display: block;
    }
  }
</style>
