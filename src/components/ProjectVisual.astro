---
import { Maximize2 } from '@lucide/astro';

interface Props {
  name: string;
  visual: {
    kind: 'image' | 'diagram';
    src?: string | undefined;
    alt: string;
  };
  flow: string[];
}

const { name, visual, flow } = Astro.props;
const visualId = `project-visual-${name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || 'detail'}`;
const titleId = `${visualId}-title`;
const descriptionId = `${visualId}-description`;
const longDescription = `${visual.alt}. 주요 흐름은 ${flow.join('에서 ')} 순서로 이어집니다.`;
---

<figure class:list={['project-visual', `project-visual--${visual.kind}`]}>
  {visual.kind === 'image' && visual.src ? (
    <div class="visual-media">
      <img src={visual.src} alt={visual.alt} aria-describedby={descriptionId} loading="eager" fetchpriority="high" decoding="async" />
      <a
        class="original-link"
        href={visual.src}
        target="_blank"
        rel="noreferrer"
        aria-label={`${name} 이미지 원본 새 창에서 열기`}
      >
        <Maximize2 size={16} aria-hidden="true" />
        <span>원본 보기</span>
      </a>
    </div>
  ) : (
    <div class="diagram-viewport" role="region" aria-label={`${name} 구성도. 가로로 스크롤할 수 있습니다.`} tabindex="0">
      <div class="generated-diagram" aria-labelledby={titleId} aria-describedby={descriptionId}>
        <div class="diagram-title"><span id={titleId}>{name}</span><small>요청 처리 흐름</small></div>
        <ol role="list">
          {flow.map((step, index) => (
            <li role="listitem">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <strong>{step}</strong>
            </li>
          ))}
        </ol>
      </div>
    </div>
  )}
  <figcaption id={descriptionId}>{longDescription}</figcaption>
</figure>

<style>
  .project-visual {
    margin: 0;
  }

  .visual-media,
  .generated-diagram {
    width: 100%;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .visual-media {
    position: relative;
    display: grid;
    min-height: 280px;
    place-items: center;
    padding: 12px;
  }

  .visual-media img {
    width: auto;
    max-width: 100%;
    max-height: min(72vh, 760px);
    object-fit: contain;
  }

  .original-link {
    display: inline-flex;
    justify-self: end;
    min-height: 44px;
    align-items: center;
    gap: 7px;
    margin-top: 10px;
    padding: 8px 11px;
    border: 1px solid var(--line-strong);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 2px 10px rgba(23, 26, 29, 0.14);
    font-size: 0.86rem;
    font-weight: 850;
    text-decoration: none;
  }

  .diagram-viewport {
    overflow-x: auto;
    overscroll-behavior-inline: contain;
  }

  .diagram-viewport:focus-visible {
    outline: 3px solid #ffcf70;
    outline-offset: 4px;
  }

  .generated-diagram {
    min-height: 360px;
    padding: 22px;
    background-color: #101417;
    color: white;
  }

  .diagram-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-bottom: 18px;
    border-bottom: 1px solid #3e4642;
    font-family: var(--mono);
    font-weight: 800;
  }

  .diagram-title small {
    color: #65d6ac;
    font-size: 0.82rem;
  }

  .generated-diagram ol {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 14px;
    align-items: stretch;
    margin: 58px 0 0;
    padding: 0;
    list-style: none;
  }

  .generated-diagram li {
    position: relative;
    display: grid;
    min-height: 120px;
    align-content: space-between;
    gap: 14px;
    padding: 14px;
    border: 1px solid #58615d;
    border-top: 3px solid #5da0ff;
    border-radius: 3px;
    background: rgba(16, 20, 23, 0.82);
  }

  .generated-diagram li:not(:last-child)::after {
    position: absolute;
    top: 50%;
    right: -13px;
    z-index: 1;
    color: #8ab9ff;
    content: "→";
    font-family: var(--mono);
    transform: translateY(-50%);
  }

  .generated-diagram li > span {
    color: #97a29d;
    font-family: var(--mono);
    font-size: 0.82rem;
  }

  .generated-diagram li strong {
    font-size: 0.94rem;
    line-height: 1.45;
  }

  figcaption {
    margin-top: 10px;
    color: var(--ink-faint);
    font-size: 0.86rem;
  }

  @media (max-width: 640px) {
    .visual-media {
      min-height: 0;
      padding: 8px;
    }

    .visual-media img {
      max-height: 68vh;
    }

    .generated-diagram {
      width: 720px;
      min-height: 0;
      padding: 16px;
    }

    .generated-diagram ol {
      grid-template-columns: repeat(5, minmax(120px, 1fr));
      margin-top: 30px;
    }

    .generated-diagram li {
      min-height: 100px;
    }
  }
</style>
