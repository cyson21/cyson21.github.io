---
const stages = [
  { label: 'Request', project: 'Member Event', href: '/projects/member-event-consistency/', note: '동시 요청' },
  { label: 'State', project: 'StockRush', href: '/projects/stockrush/', note: '상태 수렴' },
  { label: 'Evidence', project: 'Policy RAG', href: '/projects/enterprise-policy-rag/', note: '근거·권한' },
  { label: 'Failure', project: 'AI Gateway', href: '/projects/ai-gateway/', note: '부분 실패' },
  { label: 'Recovery', project: 'CDC Platform', href: '/projects/cdc-data-platform/', note: '재처리' },
  { label: 'Snapshot', project: 'Personalization', href: '/projects/fashion-personalization-platform/', note: '최신성' },
];
---

<div class="system-map" role="group" aria-label="요청부터 복구까지 프로젝트 연결 지도">
  <div class="map-label">
    <span class="status-label">6 projects · evidence linked</span>
    <p>정상 흐름보다 실패 이후의 상태를 먼저 설계합니다.</p>
  </div>
  <div class="map-track">
    {stages.map((stage, index) => (
      <a class="map-node" href={stage.href}>
        <span class="node-index">0{index + 1}</span>
        <span class="node-label">{stage.label}</span>
        <strong>{stage.project}</strong>
        <span class="node-note">{stage.note}</span>
        {index < stages.length - 1 && <span class="map-connector" aria-hidden="true">→</span>}
      </a>
    ))}
  </div>
</div>

<style>
  .system-map {
    padding: 24px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: var(--shadow);
  }

  .map-label {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 22px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.83rem;
  }

  .map-track {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 8px;
  }

  .map-node {
    position: relative;
    display: grid;
    min-width: 0;
    min-height: 150px;
    align-content: space-between;
    gap: 6px;
    padding: 14px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--surface-muted);
    text-decoration: none;
  }

  .map-connector {
    position: absolute;
    top: 50%;
    right: -9px;
    z-index: 2;
    display: grid;
    width: 18px;
    height: 18px;
    place-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    background: var(--surface);
    color: var(--blue);
    font-family: var(--mono);
    font-size: 0.68rem;
    transform: translateY(-50%);
  }

  .map-node:hover {
    border-color: var(--blue);
    background: var(--blue-soft);
    color: var(--ink);
  }

  .node-index,
  .node-note {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.66rem;
  }

  .node-label {
    color: var(--blue);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .map-node strong {
    font-size: 0.95rem;
    line-height: 1.35;
  }

  @media (max-width: 880px) {
    .map-track {
      grid-template-columns: 1fr 1fr;
    }

    .map-node {
      min-height: 125px;
    }

    .map-connector {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .system-map {
      padding: 12px;
    }

    .map-label {
      flex-direction: column;
      gap: 6px;
      margin-bottom: 12px;
      padding-bottom: 12px;
    }

    .map-track {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    .map-node {
      min-height: 66px;
      grid-template-columns: 28px minmax(0, 1fr) auto;
      grid-template-rows: auto auto;
      align-items: center;
      gap: 2px 8px;
      padding: 9px 10px;
    }

    .node-index {
      grid-column: 1;
      grid-row: 1;
    }

    .node-label {
      grid-column: 2;
      grid-row: 1;
    }

    .map-node strong {
      grid-column: 1 / 3;
      grid-row: 2;
    }

    .node-note {
      grid-column: 3;
      grid-row: 1 / 3;
      text-align: right;
    }
  }
</style>
