---
const stages = [
  { label: '요청', project: 'Member Event', href: '/projects/member-event-consistency/', note: '동시 요청' },
  { label: '상태', project: 'StockRush', href: '/projects/stockrush/', note: '상태 수렴' },
  { label: '근거', project: 'Policy RAG', href: '/projects/enterprise-policy-rag/', note: '권한 검증' },
  { label: '실패', project: 'AI Gateway', href: '/projects/ai-gateway/', note: '부분 실패' },
  { label: '복구', project: 'CDC Platform', href: '/projects/cdc-data-platform/', note: '재처리' },
  { label: '시점', project: 'Personalization', href: '/projects/fashion-personalization-platform/', note: '최신성' },
];
---

<div class="system-map" role="group" aria-label="요청부터 복구까지 프로젝트 연결 지도">
  <div class="map-label">
    <span class="status-label">6개 프로젝트 · 구현 근거 연결</span>
    <p>정상 흐름보다 실패 이후의 상태를 먼저 설계합니다.</p>
  </div>
  <div class="map-track">
    {stages.map((stage, index) => (
      <a class="map-node" href={stage.href}>
        <span class="node-index">0{index + 1}</span>
        <span class="node-label">{stage.label}</span>
        <strong>{stage.project}</strong>
        <span class="node-note">{stage.note}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .system-map {
    border-top: 3px solid var(--blue);
    background: var(--surface);
  }

  .map-label {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding: 16px 18px;
    border-inline: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  .map-track {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    border-left: 1px solid var(--line-strong);
  }

  .map-node {
    position: relative;
    display: grid;
    min-width: 0;
    min-height: 138px;
    align-content: space-between;
    gap: 6px;
    padding: 16px;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    background: transparent;
    text-decoration: none;
  }

  .map-node:hover {
    background: var(--blue-soft);
    color: var(--ink);
  }

  .node-index,
  .node-note {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.82rem;
  }

  .node-label {
    color: var(--blue);
    font-family: var(--mono);
    font-size: 0.84rem;
    font-weight: 800;
  }

  .map-node strong {
    font-size: 1rem;
    line-height: 1.35;
  }

  @media (max-width: 880px) {
    .map-track {
      grid-template-columns: 1fr 1fr;
    }

    .map-node {
      min-height: 118px;
    }
  }

  @media (max-width: 560px) {
    .system-map {
      padding: 0;
    }

    .map-label {
      flex-direction: column;
      gap: 0;
      margin-bottom: 12px;
      padding-bottom: 12px;
    }

    .map-track {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    .map-node {
      min-height: 74px;
      grid-template-columns: 28px minmax(0, 1fr) auto;
      grid-template-rows: auto auto;
      align-items: center;
      gap: 3px 10px;
      padding: 11px 12px;
    }

    .node-index {
      grid-column: 1;
      grid-row: 1;
    }

    .node-label {
      grid-column: 2;
      grid-row: 1;
    }

    .map-node strong {
      grid-column: 1 / 3;
      grid-row: 2;
    }

    .node-note {
      grid-column: 3;
      grid-row: 1 / 3;
      text-align: right;
    }
  }
</style>
