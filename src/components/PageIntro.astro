---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="page-intro section--compact">
  <div class="container intro-grid">
    <p class="intro-label">{eyebrow}</p>
    <div class="intro-copy">
      <h1>{title}</h1>
      <p class="lede">{description}</p>
    </div>
  </div>
</section>

<style>
  .page-intro {
    padding-block: 58px 54px;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: 36px;
    align-items: start;
  }

  .intro-label {
    margin-top: 8px;
    color: var(--blue);
    font-size: var(--text-label);
    font-weight: 760;
  }

  .intro-label::before {
    display: inline-block;
    width: 22px;
    height: 3px;
    margin-right: 10px;
    background: var(--blue);
    content: "";
    vertical-align: 0.2em;
  }

  .intro-copy {
    max-width: 900px;
  }

  .intro-copy h1 {
    font-size: 3.1rem;
  }

  .intro-copy .lede {
    max-width: 760px;
    margin-top: 18px;
  }

  @media (max-width: 820px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .intro-label {
      margin-top: 0;
    }
  }

  @media (max-width: 520px) {
    .page-intro {
      padding-block: 34px 32px;
    }

    .intro-copy h1 {
      font-size: 2.25rem;
    }

    .intro-copy .lede {
      margin-top: 12px;
    }
  }
</style>
