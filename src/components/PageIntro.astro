---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="page-intro section--compact">
  <div class="container intro-grid">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
    </div>
    <p class="lede">{description}</p>
  </div>
</section>

<style>
  .page-intro {
    padding-top: 76px;
    border-bottom: 1px solid var(--line);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.7fr);
    gap: 48px;
    align-items: end;
  }

  .intro-grid h1 {
    font-size: 5rem;
  }

  @media (max-width: 820px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      align-items: start;
    }

    .intro-grid h1 {
      font-size: 3.8rem;
    }
  }

  @media (max-width: 520px) {
    .intro-grid h1 {
      font-size: 2.7rem;
    }
  }
</style>
