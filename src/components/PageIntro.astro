---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="page-intro section--compact">
  <div class="container intro-grid">
    <div class="intro-copy">
      {eyebrow && <p class="intro-label">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="lede">{description}</p>
    </div>
  </div>
</section>

<style>
  .page-intro {
    padding-block: 48px;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .intro-grid {
    display: block;
  }

  .intro-label {
    margin-bottom: 12px;
    color: var(--blue);
    font-size: var(--text-label);
    font-weight: 760;
  }

  .intro-copy {
    max-width: 900px;
  }

  .intro-copy h1 {
    font-size: var(--text-h1);
  }

  .intro-copy .lede {
    max-width: 760px;
    margin-top: 18px;
  }

  @media (max-width: 639px) {
    .page-intro {
      padding-block: 36px;
    }

    .intro-copy .lede {
      margin-top: 12px;
    }
  }
</style>
